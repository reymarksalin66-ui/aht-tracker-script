    const POSITION_STORAGE_KEY = 'aht_panel_position_v2';
    const SIZE_STORAGE_KEY = 'aht_panel_size_v2';
    const TIMER_STATE_KEY = 'aht_timer_state_v1';
    const EMAIL_QUEUE_PATTERN = /(claims-atoz-inquiries-sesu|trms-pi-claims-cs-escalation-claims|claims-asor-inquiries-sss)@amazon\.[a-z.]+/i;
    const PHOTON_PATTERN = /entityType=UnitOfWork/i;

    // STATE ────────────────────────────────────────────────────────────────
    let timerInterval    = null;
    let startTime        = null;
    let elapsedSeconds   = 0;
    let isRunning        = false;
    let currentCaseId    = detectCaseId();
    let currentCaseType  = 'nonemail';
    let currentQueueName = '';
    let caseStartTimestamp = null;
    let helpPanelOpen    = false;
    let panelCheckerInterval = null;
    let timerResumedFromState = false;

    // ⭐ V2.27 DRAG/RESIZE STATE
    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;
    let isResizing = false;
    let resizeStartX = 0;
    let resizeStartY = 0;
    let resizeStartWidth = 0;
    let resizeStartHeight = 0;
    let eventsAttached = false;

    function detectCaseId() {
        const photonMatch = window.location.href.match(/entityId=([^&]+)/i);
        if (photonMatch) return 'UOW-' + decodeURIComponent(photonMatch[1]).substring(0, 20);

        const caseIdParam = new URLSearchParams(window.location.search).get('caseId');
        if (caseIdParam) return caseIdParam;
        const idParam = new URLSearchParams(window.location.search).get('id');
        if (idParam) return idParam;
        const pathMatch = window.location.href.match(/\/(cases|investigation|view-case)\/([A-Z0-9\-]+)/i);
        if (pathMatch) return pathMatch[2];
        return 'UNKNOWN-' + Date.now();
    }

    function detectCaseType() {
        if (PHOTON_PATTERN.test(window.location.href)) {
            currentCaseType = 'photon';
            currentQueueName = 'Photon Fallback';
            return currentCaseType;
        }

        const bodyText = document.body ? (document.body.innerText || '') : '';
        const queuePatterns = [
            /Queue[:\s]+([^\r\n]+)/i,
            /Queue Name[:\s]+([^\r\n]+)/i,
            /Assigned Queue[:\s]+([^\r\n]+)/i
        ];
        let queueName = '';
        for (const pattern of queuePatterns) {
            const match = bodyText.match(pattern);
            if (match) { queueName = match[1].trim(); break; }
        }
        currentQueueName = queueName;
        currentCaseType = EMAIL_QUEUE_PATTERN.test(currentQueueName) ? 'email' : 'nonemail';
        return currentCaseType;
    }

    function formatTime(seconds) {
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = (seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
    }

    function secondsToMinutes(seconds) {
        return parseFloat((seconds / 60).toFixed(2));
    }

    function calcDAG(actualSeconds, caseType) {
        if (actualSeconds === 0) return null;
        return ((AHT_GOALS[caseType] / actualSeconds) * 100).toFixed(1);
    }

    function calcWeightedStats(log) {
        if (log.length === 0) return null;

        let emailCount = 0, nonEmailCount = 0, photonCount = 0;
        let emailTotal = 0, nonEmailTotal = 0, photonTotal = 0;

        for (const entry of log) {
            if (entry.caseType === 'email') {
                emailCount++;
                emailTotal += entry.duration;
            } else if (entry.caseType === 'photon') {
                photonCount++;
                photonTotal += entry.duration;
            } else {
                nonEmailCount++;
                nonEmailTotal += entry.duration;
            }
        }

        const totalCases = emailCount + nonEmailCount + photonCount;
        const emailWeight = emailCount / totalCases;
        const nonEmailWeight = nonEmailCount / totalCases;
        const photonWeight = photonCount / totalCases;

        const avgEmailAHT = emailCount > 0 ? emailTotal / emailCount : 0;
        const avgNonEmailAHT = nonEmailCount > 0 ? nonEmailTotal / nonEmailCount : 0;
        const avgPhotonAHT = photonCount > 0 ? photonTotal / photonCount : 0;
        const emailDAG = emailCount > 0 ? ((AHT_GOALS.email / avgEmailAHT) * 100).toFixed(1) : null;
        const nonEmailDAG = nonEmailCount > 0 ? ((AHT_GOALS.nonemail / avgNonEmailAHT) * 100).toFixed(1) : null;
        const photonDAG = photonCount > 0 ? ((AHT_GOALS.photon / avgPhotonAHT) * 100).toFixed(1) : null;

        const weightedGoalAHT = (AHT_GOALS.email * emailWeight) + (AHT_GOALS.nonemail * nonEmailWeight) + (AHT_GOALS.photon * photonWeight);
        const weightedAchievedAHT = (avgEmailAHT * emailWeight) + (avgNonEmailAHT * nonEmailWeight) + (avgPhotonAHT * photonWeight);
        const weightedDAG = weightedAchievedAHT > 0 ? ((weightedGoalAHT / weightedAchievedAHT) * 100).toFixed(1) : null;

        const totalGoalAHT = (AHT_GOALS.email * emailCount) + (AHT_GOALS.nonemail * nonEmailCount) + (AHT_GOALS.photon * photonCount);
        const totalAchievedAHT = emailTotal + nonEmailTotal + photonTotal;

        return { weightedDAG, weightedGoalAHT, weightedAchievedAHT, totalGoalAHT, totalAchievedAHT, totalCases, emailCount, nonEmailCount, photonCount, avgEmail: avgEmailAHT, avgNonEmail: avgNonEmailAHT, avgPhoton: avgPhotonAHT, emailDAG, nonEmailDAG, photonDAG };
    }

    function exportToExcel() {
        const log = JSON.parse(GM_getValue(STORAGE_KEY, '[]'));
        if (log.length === 0) { alert('No cases logged yet.'); return; }

        const stats = calcWeightedStats(log);
        const wb = XLSX.utils.book_new();

        const caseRows = log.map((entry, idx) => ({
            '#': idx + 1, 'Case ID': entry.caseId,
            'Case Type': entry.caseType === 'email' ? 'Email' : entry.caseType === 'photon' ? 'Photon' : 'Non-Email',
            'Queue Name': entry.queueName || 'N/A',
            'Start Time': entry.startTime ? new Date(entry.startTime).toLocaleString() : 'N/A',
            'End Time': entry.timestamp ? new Date(entry.timestamp).toLocaleString() : 'N/A',
            'AHT (mm:ss)': entry.formatted,
            'AHT (minutes)': secondsToMinutes(entry.duration),
            'Goal (minutes)': secondsToMinutes(entry.goal),
            'DAG %': parseFloat(entry.dag),
            'DAG Status': parseFloat(entry.dag) >= 100 ? 'Achieved' : parseFloat(entry.dag) >= 80 ? 'Near Goal' : 'Below Goal'
        }));
        const ws1 = XLSX.utils.json_to_sheet(caseRows);
        ws1['!cols'] = [{wch:4},{wch:18},{wch:12},{wch:28},{wch:22},{wch:22},{wch:12},{wch:14},{wch:14},{wch:10},{wch:14}];
        XLSX.utils.book_append_sheet(wb, ws1, 'Case Log');

        const summaryRows = [
            { 'Metric': 'Total Cases', 'Value': stats.totalCases },
            { 'Metric': 'Email Cases', 'Value': stats.emailCount },
            { 'Metric': 'Non-Email Cases', 'Value': stats.nonEmailCount },
            { 'Metric': 'Photon Cases', 'Value': stats.photonCount }
        ];
        const ws2 = XLSX.utils.json_to_sheet(summaryRows);
        XLSX.utils.book_append_sheet(wb, ws2, 'Summary');

        XLSX.writeFile(wb, `AHT_Log_${new Date().toISOString().slice(0,10)}.xlsx`);
    }

