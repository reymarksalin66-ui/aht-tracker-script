                <span id="aht-case-type-badge" style="font-size:10px;font-weight:bold;padding:2px 7px;border-radius:10px;background:#2980b9;color:#fff;">Non-Email</span>
            </div>
            <div id="aht-case-label" style="font-size:10px;color:#aaa;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">Case: ${currentCaseId}</div>
            <div id="aht-queue-label" style="font-size:10px;color:#888;margin-bottom:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">Queue: detecting...</div>
            <div id="aht-timer-display" style="font-size:32px;font-weight:bold;text-align:center;letter-spacing:2px;color:#00d4ff;margin:6px 0;">00:00</div>
            <div id="aht-goal-label" style="text-align:center;font-size:10px;color:#888;margin-bottom:4px;">Goal: 8:00 (Non-Email)</div>
            <div id="aht-status-bar" style="height:6px;border-radius:4px;background:#00d4ff;width:0%;transition:width 0.5s,background 0.5s;margin-bottom:8px;"></div>
            <div id="aht-dag-display" style="text-align:center;font-size:12px;color:#aaa;margin-bottom:8px;">DAG: —</div>
            <div id="aht-status-msg" style="text-align:center;font-size:11px;color:#aaa;margin-bottom:10px;">Press Start to begin tracking</div>

            <div style="display:flex;gap:8px;justify-content:center;margin-bottom:8px;">
                <button id="aht-btn-start" style="${btnStyle('#27ae60', true)}">▶ START</button>
                <button id="aht-btn-stop"  style="${btnStyle('#e74c3c', true)}" disabled>⏹ STOP</button>
            </div>
            <div style="display:flex;gap:6px;justify-content:center;margin-bottom:8px;">
                <button id="aht-btn-override-email"    style="${btnStyle('#8e44ad')}">📧 Email</button>
                <button id="aht-btn-override-nonemail" style="${btnStyle('#2c3e50')}">📁 Non-Email</button>
                <button id="aht-btn-override-photon"   style="${btnStyle('#d35400')}">⚛️ Photon</button>
            </div>
            <div style="display:flex;gap:6px;justify-content:center;margin-bottom:6px;">
                <button id="aht-btn-log"    style="${btnStyle('#2980b9')}">📋 Log</button>
                <button id="aht-btn-export" style="${btnStyle('#27ae60')}">📥 Export</button>
                <button id="aht-btn-clear"  style="${btnStyle('#7f8c8d')}">🗑 Clear</button>
            </div>
            <div style="display:flex;gap:6px;justify-content:center;">
                <button id="aht-btn-help" style="${btnStyle('#16a085')}">💡 Help</button>
            </div>
            <div id="aht-log-panel" style="display:none;margin-top:10px;max-height:400px;overflow-y:auto;background:#0f0f1a;border-radius:8px;padding:8px;font-size:11px;color:#ccc;"></div>
        `;

        // Apply position and size with inline !important styles
        let positionCSS = '';
        if (position.left !== 'auto') {
            positionCSS = `left: ${position.left} !important; top: ${position.top} !important;`;
        } else {
            positionCSS = `bottom: ${position.bottom} !important; right: ${position.right} !important;`;
        }

        panel.style.cssText = `
            position: fixed !important;
            ${positionCSS}
            width: ${size.width} !important;
            height: ${size.height} !important;
        `;

        // Append ONLY to body
        document.body.appendChild(panel);
        console.log('✅ Panel created with position:', position, 'size:', size);

        // ⭐ V2.27 CRITICAL FIX: Reset event attachment flag on new panel creation
        eventsAttached = false;

        attachEvents();
        attachDragResize();
        detectCaseType();
        updateCaseTypeUI();

        // ⭐ Try to restore timer on panel creation
        if (!timerResumedFromState && restoreTimerState()) {
            isRunning = true;
            timerResumedFromState = true;
            startContinuousTimer();
            setButtonStates(true);
            updateStatusMsg('🟢 Tracking (Resumed)...', '#2ecc71');
            console.log('🟢 Timer resumed from refresh!');
        }

        return panel;
    }

    // ⭐ Start continuous timer (for restored state)
    function startContinuousTimer() {
        if (timerInterval) clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            elapsedSeconds = Math.floor((Date.now() - startTime) / 1000);
            updateDisplay();
            saveTimerState();
        }, 1000);
    }

    // ⭐ V2.27 FIXED RESIZE (With proper event reattachment)
    function attachDragResize() {
        const panel = document.getElementById('aht-tracker-panel');
        const header = document.getElementById('aht-panel-header');
        const resizeHandle = document.getElementById('aht-resize-handle');

        if (!panel || !header) {
            console.error('❌ Panel or header not found');
            return;
        }

        console.log('✅ V2.27: Attaching drag/resize handlers...');

        // ⭐ DRAG FUNCTIONALITY
        header.addEventListener('mousedown', (e) => {
            if (e.button !== 0) return; // Only left mouse button
            isDragging = true;
            const rect = panel.getBoundingClientRect();
            dragOffsetX = e.clientX - rect.left;
            dragOffsetY = e.clientY - rect.top;
            panel.classList.add('dragging');
            console.log('🟡 Drag started');
            e.preventDefault();
        });

        // ⭐ GLOBAL MOUSEMOVE (handles both drag and resize)
        document.addEventListener('mousemove', (e) => {
            if (isDragging) {
                const newX = e.clientX - dragOffsetX;
                const newY = e.clientY - dragOffsetY;

                // Keep panel within viewport
                const maxX = window.innerWidth - panel.offsetWidth;
                const maxY = window.innerHeight - panel.offsetHeight;

                const clampedX = Math.max(0, Math.min(newX, maxX));
                const clampedY = Math.max(0, Math.min(newY, maxY));

                panel.style.left = clampedX + 'px';
                panel.style.top = clampedY + 'px';
                panel.style.bottom = 'auto';
                panel.style.right = 'auto';
            }

            if (isResizing) {
                const deltaX = e.clientX - resizeStartX;
                const deltaY = e.clientY - resizeStartY;

                const newWidth = Math.max(220, resizeStartWidth + deltaX);
                const newHeight = Math.max(300, resizeStartHeight + deltaY);

                panel.style.width = newWidth + 'px';
                panel.style.height = newHeight + 'px';

                console.log('📏 Resizing:', newWidth, 'x', newHeight);
            }
        }, { passive: true });

        // ⭐ GLOBAL MOUSEUP (handles both drag and resize)
        document.addEventListener('mouseup', (e) => {
            if (isDragging) {
                isDragging = false;
                panel.classList.remove('dragging');
                savePanelState(panel);
                console.log('🟢 Drag ended and saved');
            }
            if (isResizing) {
                isResizing = false;
                savePanelState(panel);
                console.log('🟢 Resize ended and saved');
            }
        });

        // ⭐ RESIZE HANDLE MOUSEDOWN
        if (resizeHandle) {
            resizeHandle.addEventListener('mousedown', (e) => {
                if (e.button !== 0) return; // Only left mouse button
                e.preventDefault();
                e.stopPropagation();
                isResizing = true;
                resizeStartX = e.clientX;
                resizeStartY = e.clientY;
                resizeStartWidth = panel.offsetWidth;
                resizeStartHeight = panel.offsetHeight;
                resizeHandle.style.opacity = '1';
                console.log('🟡 Resize started:', resizeStartWidth, 'x', resizeStartHeight);
            });
        }

        // ⭐ TOUCH SUPPORT
        header.addEventListener('touchstart', (e) => {
            if (e.touches.length !== 1) return;
            isDragging = true;
            const rect = panel.getBoundingClientRect();
            dragOffsetX = e.touches[0].clientX - rect.left;
            dragOffsetY = e.touches[0].clientY - rect.top;
        });

        document.addEventListener('touchmove', (e) => {
            if (!isDragging || e.touches.length !== 1) return;

            const newX = e.touches[0].clientX - dragOffsetX;
            const newY = e.touches[0].clientY - dragOffsetY;

            const maxX = window.innerWidth - panel.offsetWidth;
            const maxY = window.innerHeight - panel.offsetHeight;

            panel.style.left = Math.max(0, Math.min(newX, maxX)) + 'px';
            panel.style.top = Math.max(0, Math.min(newY, maxY)) + 'px';
            panel.style.bottom = 'auto';
            panel.style.right = 'auto';
        }, { passive: true });

        document.addEventListener('touchend', () => {
            if (isDragging) {
                isDragging = false;
                savePanelState(panel);
            }
        });

        console.log('✅ All event listeners attached successfully');
    }

    function updateDisplay() {
        const display = document.getElementById('aht-timer-display');
        const bar = document.getElementById('aht-status-bar');
        const dagDisplay = document.getElementById('aht-dag-display');
        if (!display || !bar) return;

        const goal = AHT_GOALS[currentCaseType];
        display.textContent = formatTime(elapsedSeconds);

        const pct = Math.min((elapsedSeconds / goal) * 100, 100);
        bar.style.width = pct + '%';

        const dag = calcDAG(elapsedSeconds, currentCaseType);
        if (dag !== null && dagDisplay) {
            const dagVal = parseFloat(dag);
            const dagColor = dagVal >= 100 ? '#2ecc71' : dagVal >= 80 ? '#f39c12' : '#e74c3c';
            dagDisplay.textContent = `DAG: ${dag}%`;
            dagDisplay.style.color = dagColor;
        }

        const warningAt = goal * 0.75;
        if (elapsedSeconds >= goal) {
            display.style.color = '#e74c3c';
            bar.style.background = '#e74c3c';
            updateStatusMsg('🚨 AHT Critical!', '#e74c3c');
        } else if (elapsedSeconds >= warningAt) {
            display.style.color = '#f39c12';
            bar.style.background = '#f39c12';
            updateStatusMsg('⚠️ Approaching goal', '#f39c12');
        } else {
            display.style.color = '#00d4ff';
            bar.style.background = '#00d4ff';
            updateStatusMsg('🟢 Tracking...', '#2ecc71');
        }
    }

    function updateStatusMsg(msg, color = '#aaa') {
        const el = document.getElementById('aht-status-msg');
        if (el) { el.textContent = msg; el.style.color = color; }
    }

    function updateCaseTypeUI() {
        const badge = document.getElementById('aht-case-type-badge');
        const goalLabel = document.getElementById('aht-goal-label');
        const queueLabel = document.getElementById('aht-queue-label');
        if (!badge) return;
        if (currentCaseType === 'email') {
            badge.textContent = 'Email';
            badge.style.background = '#8e44ad';
            if (goalLabel) goalLabel.textContent = 'Goal: 4:30 (Email)';
        } else if (currentCaseType === 'photon') {
            badge.textContent = 'Photon';
            badge.style.background = '#d35400';
            if (goalLabel) goalLabel.textContent = 'Goal: 8:00 (Photon)';
        } else {
            badge.textContent = 'Non-Email';
            badge.style.background = '#2980b9';
            if (goalLabel) goalLabel.textContent = 'Goal: 8:00 (Non-Email)';
        }
        if (queueLabel) queueLabel.textContent = currentQueueName ? `Queue: ${currentQueueName}` : 'Queue: not detected';
    }

    function setButtonStates(running) {
        const s = document.getElementById('aht-btn-start');
        const x = document.getElementById('aht-btn-stop');
        if (s) s.disabled = running;
        if (x) x.disabled = !running;
    }

    function startTimer() {
        if (isRunning) return;
        detectCaseType();
        isRunning = true;
        caseStartTimestamp = new Date().toISOString();
        startTime = Date.now() - (elapsedSeconds * 1000);
        timerInterval = setInterval(() => {
            elapsedSeconds = Math.floor((Date.now() - startTime) / 1000);
            updateDisplay();
            saveTimerState();
        }, 1000);
        setButtonStates(true);
        updateStatusMsg('🟢 Tracking...', '#2ecc71');
    }

    function stopTimer() {
        clearInterval(timerInterval);
        isRunning = false;
        const dag = calcDAG(elapsedSeconds, currentCaseType);
        const log = JSON.parse(GM_getValue(STORAGE_KEY, '[]'));
        log.push({
            caseId: currentCaseId, caseType: currentCaseType, queueName: currentQueueName,
            duration: elapsedSeconds, formatted: formatTime(elapsedSeconds),
            goal: AHT_GOALS[currentCaseType], dag: dag,
            startTime: caseStartTimestamp, timestamp: new Date().toISOString()
        });
        GM_setValue(STORAGE_KEY, JSON.stringify(log));
        saveTimerState();
        updateStatusMsg(`✅ Saved | DAG: ${dag}%`, '#00d4ff');
        setButtonStates(false);

        setTimeout(() => {
            elapsedSeconds = 0;
            caseStartTimestamp = null;
            currentCaseId = detectCaseId();
            const display = document.getElementById('aht-timer-display');
            const bar = document.getElementById('aht-status-bar');
            const caseLabel = document.getElementById('aht-case-label');
            const dagDisplay = document.getElementById('aht-dag-display');
            const btn = document.getElementById('aht-btn-start');
            if (display) { display.textContent = '00:00'; display.style.color = '#00d4ff'; }
            if (bar) { bar.style.width = '0%'; bar.style.background = '#00d4ff'; }
            if (caseLabel) caseLabel.textContent = `Case: ${currentCaseId}`;
            if (dagDisplay) dagDisplay.textContent = 'DAG: —';
            if (btn) btn.disabled = false;
            updateStatusMsg('Press Start to begin tracking', '#aaa');
            detectCaseType();
            updateCaseTypeUI();
        }, 3000);
    }

    function attachEvents() {
        const startBtn = document.getElementById('aht-btn-start');
        const stopBtn = document.getElementById('aht-btn-stop');
        const emailBtn = document.getElementById('aht-btn-override-email');
        const nonEmailBtn = document.getElementById('aht-btn-override-nonemail');
        const photonBtn = document.getElementById('aht-btn-override-photon');
        const logBtn = document.getElementById('aht-btn-log');
        const exportBtn = document.getElementById('aht-btn-export');
        const clearBtn = document.getElementById('aht-btn-clear');
        const helpBtn = document.getElementById('aht-btn-help');

        if (startBtn) startBtn.addEventListener('click', startTimer);
        if (stopBtn) stopBtn.addEventListener('click', stopTimer);

        if (emailBtn) emailBtn.addEventListener('click', () => {
            currentCaseType = 'email';
            updateCaseTypeUI();
            updateStatusMsg('📧 Email', '#8e44ad');
        });

        if (nonEmailBtn) nonEmailBtn.addEventListener('click', () => {
            currentCaseType = 'nonemail';
            updateCaseTypeUI();
            updateStatusMsg('📁 Non-Email', '#2980b9');
        });

        if (photonBtn) photonBtn.addEventListener('click', () => {
            currentCaseType = 'photon';
            updateCaseTypeUI();
            updateStatusMsg('⚛️ Photon', '#d35400');
        });

        if (logBtn) {
            logBtn.addEventListener('click', () => {
                const logPanel = document.getElementById('aht-log-panel');
                if (logPanel) {
                    logPanel.style.display = logPanel.style.display === 'none' ? 'block' : 'none';
                    if (logPanel.style.display === 'block') {
                        const log = JSON.parse(GM_getValue(STORAGE_KEY, '[]'));
                        const stats = calcWeightedStats(log);
                        if (log.length > 0) {
                            let html = `<div style="font-size:10px;margin-bottom:8px;border-bottom:1px solid #333;padding-bottom:8px;"><strong>Weighted DAG:</strong> ${stats.weightedDAG}%</div>`;

                            html += `<div style="font-size:10px;margin-bottom:8px;border-bottom:1px solid #333;padding-bottom:8px;">
                                <strong>Category DAG:</strong><br>
                                📧 Email: ${stats.emailDAG ? stats.emailDAG + '%' : 'N/A'} (${stats.emailCount} cases)<br>
                                📁 Non-Email: ${stats.nonEmailDAG ? stats.nonEmailDAG + '%' : 'N/A'} (${stats.nonEmailCount} cases)<br>
                                ⚛️ Photon: ${stats.photonDAG ? stats.photonDAG + '%' : 'N/A'} (${stats.photonCount} cases)
                            </div>`;

                            html += log.slice(-10).reverse().map(e => `<div style="margin:4px 0;padding:4px;border-bottom:1px solid #333;font-size:9px;">${e.caseId} | ${e.formatted} | DAG: ${e.dag}%</div>`).join('');
                            logPanel.innerHTML = html;
                        }
                    }
                }
            });
        }

        if (exportBtn) {
            exportBtn.addEventListener('click', exportToExcel);
        }

        if (clearBtn) {
            clearBtn.addEventListener('click', () => {
                if (confirm('🗑 Clear all AHT logs? This cannot be undone.')) {
                    GM_setValue(STORAGE_KEY, '[]');
                    const logPanel = document.getElementById('aht-log-panel');
                    if (logPanel) {
                        logPanel.innerHTML = '<em style="color:#aaa;">All logs cleared.</em>';
                    }
                    updateStatusMsg('✅ Logs cleared', '#2ecc71');
                }
            });
        }

        if (helpBtn) {
            helpBtn.addEventListener('click', () => {
                console.log('💡 Help button clicked');
                toggleHelpPanel();
            });
        }
    }

    // ⭐ AGGRESSIVE PANEL CHECKER - Every 200ms
    function startPanelChecker() {
        if (panelCheckerInterval) clearInterval(panelCheckerInterval);

        panelCheckerInterval = setInterval(() => {
            try {
                ensurePanelExists();
            } catch (e) {
                console.error('Panel checker error:', e);
            }
        }, 200);
    }

    // INITIALIZATION
    function init() {
        console.log('🚀 AHT Tracker v2.27 initializing...');
        ensurePanelExists();
        startPanelChecker();
    }

    if (document.body) {
        init();
    } else {
        document.addEventListener('DOMContentLoaded', init);
        setTimeout(init, 200);
    }

    window.addEventListener('load', init);
    window.addEventListener('beforeunload', () => {
        saveTimerState();
        if (timerInterval) clearInterval(timerInterval);
        if (panelCheckerInterval) clearInterval(panelCheckerInterval);
    });
})();
