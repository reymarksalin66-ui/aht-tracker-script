        return { position, size };
    }

    // ⭐ V2.27 FIXED: Save actual height instead of always 'auto'
    function savePanelState(panel) {
        const rect = panel.getBoundingClientRect();
        const position = {
            left: rect.left > 0 ? `${Math.round(rect.left)}px` : 'auto',
            top: rect.top > 0 ? `${Math.round(rect.top)}px` : 'auto',
            bottom: rect.left > 0 ? 'auto' : `${Math.round(window.innerHeight - rect.bottom)}px`,
            right: rect.left > 0 ? 'auto' : `${Math.round(window.innerWidth - rect.right)}px`
        };
        const size = {
            width: `${Math.round(rect.width)}px`,
            height: `${Math.round(rect.height)}px`  // ⭐ FIXED: Save actual height
        };
        GM_setValue(POSITION_STORAGE_KEY, JSON.stringify(position));
        GM_setValue(SIZE_STORAGE_KEY, JSON.stringify(size));
        console.log('✅ Panel state saved:', position, size);
    }

    function saveTimerState() {
        if (!isRunning) {
            GM_setValue(TIMER_STATE_KEY, JSON.stringify({}));
            return;
        }
        const timerState = {
            isRunning: true, startTime: startTime, elapsedSeconds: elapsedSeconds,
            caseId: currentCaseId, caseType: currentCaseType, queueName: currentQueueName,
            caseStartTimestamp: caseStartTimestamp, savedAt: Date.now()
        };
        GM_setValue(TIMER_STATE_KEY, JSON.stringify(timerState));
    }

    function restoreTimerState() {
        const savedState = GM_getValue(TIMER_STATE_KEY, null);
        if (!savedState) return false;

        try {
            const state = JSON.parse(savedState);
            if (!state.isRunning) return false;

            if (state.caseId !== currentCaseId) {
                console.log(`ℹ️ Case changed: ${state.caseId} → ${currentCaseId}`);
                GM_setValue(TIMER_STATE_KEY, JSON.stringify({ isRunning: false }));
                return false;
            }

            const timeSinceRefresh = Date.now() - state.savedAt;
            const newStartTime = state.startTime + timeSinceRefresh;

            startTime = newStartTime;
            caseStartTimestamp = state.caseStartTimestamp;
            currentCaseType = state.caseType;
            currentQueueName = state.queueName;
            elapsedSeconds = Math.floor((Date.now() - startTime) / 1000);

            console.log(`✅ Timer restored! Elapsed: ${formatTime(elapsedSeconds)}`);
            return true;
        } catch (e) {
            console.error('Failed to restore timer:', e);
            return false;
        }
    }

