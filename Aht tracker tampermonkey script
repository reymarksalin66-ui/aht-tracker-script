// ==UserScript==
// @name         OTC GWF AHT Tracker (v3.3.4 PHOTON FIX)
// @namespace    http://tampermonkey.net/
// @version      3.3.5
// @description  Phase 1 fixes + Case exclusion (per-instance) + UNDO (30s) + Daily/Weekly stats + RESPONSIVE LAYOUT + PROPER MINIMIZE + FIXED PHOTON CASE DETECTION + VIEW-CASE URL SUPPORT
// @author       SEPO Team - Advanced Build
// @match        https://paragon.amazon.com/hz/*
// @match        https://paragon-na.amazon.com/hz/*
// @match        https://paragon-eu.amazon.com/hz/*
// @match        https://paragon-fe.amazon.com/hz/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_notification
// @grant        GM_xmlhttpRequest
// @require      https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js
// @run-at       document-end
// ==/UserScript==

(function () {
    'use strict';

    // ═════════════════════════════════════════════════════════════════════════
    // 🔒 CRITICAL: URL & IFRAME VALIDATION (v3.3.5 FIX)
    // ═════════════════════════════════════════════════════════════════════════

    // ✅ DO NOT RUN IN IFRAMES
    if (window.self !== window.top) {
        console.log('⚠️ [AHT TRACKER] Running in iframe, skipping initialization');
        return;
    }

    // ✅ ONLY RUN ON SPECIFIC PAGES
    const currentUrl = window.location.href;
    const isValidPage = () => {
        // Must have /hz/ in URL (covers /hz/entity, /hz/view-case, etc)
        if (!currentUrl.includes('/hz/')) {
            return false;
        }
        return true;
    };

    if (!isValidPage()) {
        console.log('⚠️ [AHT TRACKER] Page does not match required pattern, skipping');
        return;
    }

    // ✅ PREVENT MULTIPLE SCRIPT EXECUTIONS
    if (window.AHT_TRACKER_INITIALIZED) {
        console.log('⚠️ [AHT TRACKER] Already initialized on this page, skipping');
        return;
    }
    window.AHT_TRACKER_INITIALIZED = true;

    console.log('═══════════════════════════════════════════════════════');
    console.log('  🚀 AHT TRACKER v3.3.5 - VIEW-CASE URL SUPPORT');
    console.log('═══════════════════════════════════════════════════════');

    // ═════════════════════════════════════════════════════════════════════════
    // 📋 CONFIGURATION OBJECT
    // ═════════════════════════════════════════════════════════════════════════

    const CONFIG = {
        storage: {
            log: 'aht_case_log_v3',
            position: 'aht_panel_position_v3',
            size: 'aht_panel_size_v3',
            timer: 'aht_timer_state_v3',
            minimized: 'aht_panel_minimized_v3',
            goals: 'aht_goals_v3',
            excluded: 'aht_excluded_entries_v3'
        },
        defaults: {
            email: 4.5 * 60,    // 270 seconds
            nonemail: 8.0 * 60, // 480 seconds
            photon: 8.0 * 60    // 480 seconds
        },
        patterns: {
            email: /(claims-atoz-inquiries-sesu|trms-pi-claims-cs-escalation-claims|claims-asor-inquiries-sss)@amazon\.[a-z.]+/i,
            photon: /(trms_pi_ph_uw_otc_fallback_uow|photon.*fallback|fallback.*photon)/i
        },
        timers: {
            updateFrequency: 1000,
            panelRebuild: 500,
            caseChangeDelay: 1500,
            undoWindow: 30000
        },
        ui: {
            panelWidth: 260,
            minWidth: 240,
            minHeight: 320,
            zIndex: 99999
        }
    };

    // ═════════════════════════════════════════════════════════════════════════
    // 🔧 STORAGE VALIDATION LAYER
    // ═════════════════════════════════════════════════════════════════════════

    function safeGetStorage(key, defaultValue = null) {
        try {
            const value = GM_getValue(key, null);

            if (value === null || value === undefined) {
                return defaultValue;
            }

            const parsed = JSON.parse(value);

            if (key === CONFIG.storage.log || key === CONFIG.storage.excluded) {
                if (!Array.isArray(parsed)) {
                    console.warn(`⚠️ [VALIDATION] Storage key '${key}' is not an array, resetting`);
                    return [];
                }
                if (parsed.length > 5000) {
                    console.warn(`⚠️ [VALIDATION] ${key} exceeds 5000 entries, trimming`);
                    return parsed.slice(-5000);
                }
            }

            return parsed;
        } catch (e) {
            console.error(`❌ [STORAGE ERROR] Failed to retrieve '${key}':`, e.message);
            return defaultValue;
        }
    }

    function safeSetStorage(key, value) {
        try {
            let stringValue = typeof value === 'string' ? value : JSON.stringify(value);

            JSON.parse(stringValue);

            if (stringValue.length > 5000000) {
                console.warn(`⚠️ [STORAGE] Data size: ${(stringValue.length / 1024 / 1024).toFixed(2)}MB`);
            }

            GM_setValue(key, stringValue);
            return true;
        } catch (e) {
            console.error(`❌ [STORAGE SAVE ERROR] Failed to save '${key}':`, e.message);
            return false;
        }
    }

    function validateLogEntry(entry) {
        if (!entry || typeof entry !== 'object') {
            return null;
        }

        try {
            return {
                caseId: String(entry.caseId || 'UNKNOWN').substring(0, 100),
                caseType: ['email', 'nonemail', 'photon'].includes(entry.caseType)
                    ? entry.caseType
                    : 'nonemail',
                queueName: String(entry.queueName || '').substring(0, 200),
                duration: Math.max(0, parseInt(entry.duration) || 0),
                formatted: formatTime(Math.max(0, parseInt(entry.duration) || 0)),
                goal: Math.max(60, parseInt(entry.goal) || CONFIG.defaults.nonemail),
                dag: Math.max(0, Math.min(999.9, parseFloat(entry.dag) || 0)),
                startTime: entry.startTime || new Date().toISOString(),
                timestamp: entry.timestamp || new Date().toISOString()
            };
        } catch (e) {
            console.warn('⚠️ [VALIDATION] Invalid log entry:', e.message);
            return null;
        }
    }

    function loadLogSafely() {
        try {
            const raw = safeGetStorage(CONFIG.storage.log, []);

            if (!Array.isArray(raw)) {
                console.warn('⚠️ Log storage is not an array');
                return [];
            }

            const validated = raw
                .map(validateLogEntry)
                .filter(entry => entry !== null);

            if (validated.length < raw.length) {
                console.warn(`⚠️ Filtered out ${raw.length - validated.length} corrupted entries`);
            }

            return validated;
        } catch (e) {
            console.error('❌ Error loading log:', e);
            return [];
        }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // ⭐ SPECIFIC ENTRY EXCLUSION MANAGEMENT (v3.3)
    // ═════════════════════════════════════════════════════════════════════════

    function getEntryKey(caseId, timestamp) {
        return `${caseId}|${timestamp}`;
    }

    function loadExcludedEntries() {
        return safeGetStorage(CONFIG.storage.excluded, []) || [];
    }

    function saveExcludedEntries(excludedList) {
        return safeSetStorage(CONFIG.storage.excluded, JSON.stringify(excludedList));
    }

    function toggleEntryExclusion(caseId, timestamp) {
        const excluded = loadExcludedEntries();
        const key = getEntryKey(caseId, timestamp);
        const index = excluded.indexOf(key);

        if (index > -1) {
            excluded.splice(index, 1);
            console.log(`✅ Entry ${key} now INCLUDED`);
        } else {
            excluded.push(key);
            console.log(`🚫 Entry ${key} now EXCLUDED`);
        }

        saveExcludedEntries(excluded);
        return excluded;
    }

    function isEntryExcluded(caseId, timestamp) {
        const excluded = loadExcludedEntries();
        const key = getEntryKey(caseId, timestamp);
        return excluded.includes(key);
    }

    function getExcludedEntryCount() {
        return loadExcludedEntries().length;
    }

    function findDuplicateCases(log) {
        const caseIdMap = {};
        const duplicates = [];

        for (const entry of log) {
            if (!caseIdMap[entry.caseId]) {
                caseIdMap[entry.caseId] = [];
            }
            caseIdMap[entry.caseId].push(entry);
        }

        for (const [caseId, entries] of Object.entries(caseIdMap)) {
            if (entries.length > 1) {
                duplicates.push({
                    caseId,
                    count: entries.length,
                    instances: entries
                });
            }
        }

        return duplicates;
    }

    function autoExcludeDuplicates() {
        const log = loadLogSafely();
        const duplicates = findDuplicateCases(log);

        if (duplicates.length === 0) {
            alert('✅ No duplicate cases found!');
            return false;
        }

        let excluded = 0;
        const excludedEntries = loadExcludedEntries();

        for (const dup of duplicates) {
            const instances = dup.instances.sort((a, b) =>
                new Date(a.timestamp) - new Date(b.timestamp)
            );

            for (let i = 1; i < instances.length; i++) {
                const entry = instances[i];
                const key = getEntryKey(entry.caseId, entry.timestamp);
                if (!excludedEntries.includes(key)) {
                    excludedEntries.push(key);
                    excluded++;
                }
            }
        }

        saveExcludedEntries(excludedEntries);

        console.log(`✅ Auto-excluded ${excluded} duplicate entries (kept first instance of each)`);
        return true;
    }

    // ═════════════════════════════════════════════════════════════════════════
    // 🧹 CLEANUP HANDLERS REGISTRY
    // ═════════════════════════════════════════════════════════════════════════

    const CLEANUP_HANDLERS = [];

    function registerCleanup(fn) {
        if (typeof fn === 'function') {
            CLEANUP_HANDLERS.push(fn);
        }
    }

    function executeCleanup() {
        console.log('🧹 [CLEANUP] Executing cleanup handlers...');
        let executed = 0;
        CLEANUP_HANDLERS.forEach((fn, idx) => {
            try {
                fn();
                executed++;
            } catch (e) {
                console.error(`❌ [CLEANUP ${idx}]:`, e.message);
            }
        });
        console.log(`✅ [CLEANUP] Executed ${executed}/${CLEANUP_HANDLERS.length} handlers`);
    }

    window.addEventListener('unload', executeCleanup);

    // ═════════════════════════════════════════════════════════════════════════
    // ⭐ UNDO HISTORY MANAGEMENT
    // ═════════════════════════════════════════════════════════════════════════

    let undoTimer = null;
    let lastDeletedEntry = null;
    let undoButtonVisible = false;

    function saveToUndoHistory(entry) {
        try {
            lastDeletedEntry = entry;
            undoButtonVisible = true;

            showUndoButton();

            if (undoTimer) clearTimeout(undoTimer);
            undoTimer = setTimeout(() => {
                lastDeletedEntry = null;
                undoButtonVisible = false;
                hideUndoButton();
                console.log('⏱ Undo window expired');
            }, CONFIG.timers.undoWindow);

            console.log(`💾 Undo buffer: ${entry.caseId} (${entry.formatted})`);
        } catch (e) {
            console.error('❌ Error saving to undo:', e);
        }
    }

    function undoLastDelete() {
        if (!lastDeletedEntry) {
            alert('⚠️ Nothing to undo!');
            return;
        }

        try {
            const log = loadLogSafely();
            log.push(lastDeletedEntry);

            const success = safeSetStorage(CONFIG.storage.log, JSON.stringify(log));
            if (success) {
                console.log(`✅ UNDO: Restored ${lastDeletedEntry.caseId}`);
                lastDeletedEntry = null;
                undoButtonVisible = false;
                hideUndoButton();

                if (undoTimer) clearTimeout(undoTimer);

                updateStatusMsg('✅ Restored!', '#2ecc71');
                setTimeout(() => {
                    updateStatusMsg('Tracking...', '#aaa');
                }, 2000);

                const logPanel = document.getElementById('aht-log-panel');
                if (logPanel && logPanel.style.display !== 'none') {
                    renderLog();
                }
            }
        } catch (e) {
            console.error('❌ Undo error:', e);
            alert('Error restoring case.');
        }
    }

    function showUndoButton() {
        const undoBtn = document.getElementById('aht-btn-undo');
        if (undoBtn) {
            undoBtn.style.display = 'block';
            undoBtn.style.animation = 'pulse 0.5s infinite';
        }
    }

    function hideUndoButton() {
        const undoBtn = document.getElementById('aht-btn-undo');
        if (undoBtn) {
            undoBtn.style.display = 'none';
        }
    }

    // ═════════════════════════════════════════════════════════════════════════
    // ⭐ DAILY/WEEKLY STATS CALCULATION
    // ═════════════════════════════════════════════════════════════════════════

    function getTodayDate() {
        return new Date().toISOString().slice(0, 10);
    }

    function getDateDaysAgo(days) {
        const date = new Date();
        date.setDate(date.getDate() - days);
        return date.toISOString().slice(0, 10);
    }

    function getWeekStartDate() {
        const now = new Date();
        const dayOfWeek = now.getDay();
        const diff = now.getDate() - dayOfWeek + (dayOfWeek === 0 ? -6 : 1);
        const date = new Date(now.setDate(diff));
        return date.toISOString().slice(0, 10);
    }

    function getDateFromTimestamp(timestamp) {
        return new Date(timestamp).toISOString().slice(0, 10);
    }

    function calcStatsForDateRange(log, startDate, endDate) {
        if (!Array.isArray(log) || log.length === 0) return null;

        const excluded = loadExcludedEntries();

        const filteredLog = log.filter(entry => {
            const entryDate = getDateFromTimestamp(entry.timestamp);
            const key = getEntryKey(entry.caseId, entry.timestamp);
            return entryDate >= startDate &&
                   entryDate <= endDate &&
                   !excluded.includes(key);
        });

        if (filteredLog.length === 0) return null;

        let emailCount = 0, nonEmailCount = 0, photonCount = 0;
        let emailTotal = 0, nonEmailTotal = 0, photonTotal = 0;

        for (const entry of filteredLog) {
            try {
                const duration = Math.max(0, parseInt(entry.duration) || 0);

                if (entry.caseType === 'email') {
                    emailCount++;
                    emailTotal += duration;
                } else if (entry.caseType === 'photon') {
                    photonCount++;
                    photonTotal += duration;
                } else {
                    nonEmailCount++;
                    nonEmailTotal += duration;
                }
            } catch (e) {
                console.warn('⚠️ Error processing entry:', e);
            }
        }

        const totalCases = emailCount + nonEmailCount + photonCount;
        if (totalCases === 0) return null;

        const emailWeight = emailCount / totalCases;
        const nonEmailWeight = nonEmailCount / totalCases;
        const photonWeight = photonCount / totalCases;

        const avgEmailAHT = emailCount > 0 ? emailTotal / emailCount : 0;
        const avgNonEmailAHT = nonEmailCount > 0 ? nonEmailTotal / nonEmailCount : 0;
        const avgPhotonAHT = photonCount > 0 ? photonTotal / photonCount : 0;

        const emailDAG = emailCount > 0 ? ((AHT_GOALS.email / avgEmailAHT) * 100).toFixed(1) : null;
        const nonEmailDAG = nonEmailCount > 0 ? ((AHT_GOALS.nonemail / avgNonEmailAHT) * 100).toFixed(1) : null;
        const photonDAG = photonCount > 0 ? ((AHT_GOALS.photon / avgPhotonAHT) * 100).toFixed(1) : null;

        const weightedGoalAHT = (AHT_GOALS.email * emailWeight) +
                                (AHT_GOALS.nonemail * nonEmailWeight) +
                                (AHT_GOALS.photon * photonWeight);
        const weightedAchievedAHT = (avgEmailAHT * emailWeight) +
                                    (avgNonEmailAHT * nonEmailWeight) +
                                    (avgPhotonAHT * photonWeight);
        const weightedDAG = weightedAchievedAHT > 0
            ? ((weightedGoalAHT / weightedAchievedAHT) * 100).toFixed(1)
            : null;

        return {
            startDate,
            endDate,
            caseCount: totalCases,
            emailCount,
            nonEmailCount,
            photonCount,
            avgEmailAHT,
            avgNonEmailAHT,
            avgPhotonAHT,
            emailDAG,
            nonEmailDAG,
            photonDAG,
            weightedDAG,
            weightedGoalAHT,
            weightedAchievedAHT,
            totalDuration: emailTotal + nonEmailTotal + photonTotal
        };
    }

    function getTodayStats() {
        const log = loadLogSafely();
        const today = getTodayDate();
        return calcStatsForDateRange(log, today, today);
    }

    function getWeekStats() {
        const log = loadLogSafely();
        const weekStart = getWeekStartDate();
        const today = getTodayDate();
        return calcStatsForDateRange(log, weekStart, today);
    }

    function getMonthStats() {
        const log = loadLogSafely();
        const today = getTodayDate();
        const monthStart = today.slice(0, 8) + '01';
        return calcStatsForDateRange(log, monthStart, today);
    }

    function getLast7DaysStats() {
        const log = loadLogSafely();
        const today = getTodayDate();
        const sevenDaysAgo = getDateDaysAgo(6);
        return calcStatsForDateRange(log, sevenDaysAgo, today);
    }

    // ═════════════════════════════════════════════════════════════════════════
    // 📊 STATE VARIABLES
    // ═════════════════════════════════════════════════════════════════════════

    let AHT_GOALS = { ...CONFIG.defaults };

    let timerInterval = null;
    let mutationObserver = null;
    let rebuildTimeout = null;
    let urlCheckTimeout = null;

    let startTime = null;
    let elapsedSeconds = 0;
    let isRunning = false;
    let currentCaseId = detectCaseId();
    let currentCaseType = 'nonemail';
    let currentQueueName = '';
    let caseStartTimestamp = null;

    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;
    let isResizing = false;
    let resizeStartX = 0;
    let resizeStartY = 0;
    let resizeStartWidth = 0;
