// ==UserScript==
// @name         OTC GWF AHT Tracker
// @namespace    http://tampermonkey.net/
// @version      2.21
// @description  Tracks AHT per case with case-count weighted DAG, Excel export - DRAGGABLE & RESIZABLE - ALL MARKETPLACES & QUEUES - INCLUDES PHOTON FALLBACK
// @author       SEPO Team
// @match        https://paragon.amazon.com/*
// @match        https://paragon-na.amazon.com/*
// @match        https://paragon-eu.amazon.com/*
// @match        https://paragon-fe.amazon.com/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_notification
// @grant        GM_xmlhttpRequest
// @require      https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js
// ==/UserScript==

(function () {
    'use strict';

    // ─── ULTRA AGGRESSIVE DUPLICATE PREVENTION ────────────────────────────────
    // Generate unique ID for this script instance
    const SCRIPT_INSTANCE_ID = 'AHT_TRACKER_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
    const INSTANCE_STORAGE_KEY = 'aht_tracker_instance_id';

    // Try to get stored instance ID
    let storedInstanceId = sessionStorage.getItem(INSTANCE_STORAGE_KEY);

    if (storedInstanceId && storedInstanceId !== SCRIPT_INSTANCE_ID) {
        console.warn(`⚠️ DUPLICATE SCRIPT DETECTED!`);
        console.warn(`📌 Current Instance: ${SCRIPT_INSTANCE_ID}`);
        console.warn(`📌 Stored Instance: ${storedInstanceId}`);
        console.warn(`🛑 EXITING TO PREVENT DUPLICATES - Please remove duplicate script from Tampermonkey!`);
        console.warn(`\n📋 TO FIX:\n1. Go to Tampermonkey Dashboard\n2. Find "OTC GWF AHT Tracker"\n3. If you see MULTIPLE entries, delete all but ONE\n4. Refresh this page`);
        return;
    }

    // Store this instance ID
    sessionStorage.setItem(INSTANCE_STORAGE_KEY, SCRIPT_INSTANCE_ID);
    console.log(`✅ AHT Tracker v2.21 - Instance: ${SCRIPT_INSTANCE_ID.substr(0, 20)}...`);

    // ─── KILL ALL DUPLICATE PANELS IMMEDIATELY ────────────────────────────────
    function nukeAllDuplicates() {
        const allPanels = document.querySelectorAll('[id*="aht"]');
        let duplicateCount = 0;

        allPanels.forEach(panel => {
            // Only keep the most recently created panel
            if (panel.id.includes('aht-tracker-panel')) {
                duplicateCount++;
                if (duplicateCount > 1) {
                    console.log(`🗑️ NUKING duplicate panel: ${panel.id}`);
                    panel.remove();
                }
            }
        });

        if (duplicateCount > 1) {
            console.warn(`⚠️ Removed ${duplicateCount - 1} duplicate panel(s)!`);
        }
    }

    // Nuke duplicates immediately on load
    nukeAllDuplicates();

    // CONFIG ───────────────────────────────────────────────────────────────
    const AHT_GOALS = {
        email:    4.5 * 60,   // 270 seconds
        nonemail: 8.0 * 60,   // 480 seconds
        photon:   8.0 * 60    // 480 seconds (Photon fallback)
    };
    const STORAGE_KEY = 'aht_case_log_v2';
    const POSITION_STORAGE_KEY = 'aht_panel_position_v1';
    const SIZE_STORAGE_KEY = 'aht_panel_size_v1';
    const EMAIL_QUEUE_PATTERN = /(claims-atoz-inquiries-sesu|trms-pi-claims-cs-escalation-claims|claims-asor-inquiries-sss)@amazon\.[a-z.]+/i;
    const PHOTON_QUEUE_PATTERN = /(trms_pi_ph_uw_otc_fallback_uow|photon.*fallback|fallback.*photon)/i;
    const PHOTON_URL_PATTERN = /hz\/entity.*entityType=UnitOfWork/i;

    // STATE ────────────────────────────────────────────────────────────────
    let timerInterval    = null;
    let startTime        = null;
    let elapsedSeconds   = 0;
    let isRunning        = false;
    let currentCaseId    = detectCaseId();
    let currentCaseType  = 'nonemail';
    let currentQueueName = '';
    let caseStartTimestamp = null;
    let rebuildTimeout   = null;
    let helpPanelOpen    = false;
    let mutationObserver = null;
    let panelBuildAttempts = 0;

    // DRAGGING STATE ───────────────────────────────────────────────────────
    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;
    let isResizing = false;
    let resizeStartX = 0;
    let resizeStartY = 0;
    let resizeStartWidth = 0;
    let resizeStartHeight = 0;

    // ATOM ICON SVG ────────────────────────────────────────────────────────
    function getAtomSVG() {
        return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:inline;margin-right:4px;vertical-align:text-bottom;">
            <circle cx="12" cy="12" r="2" stroke="currentColor" fill="none"/>
            <ellipse cx="12" cy="12" rx="6" ry="3" stroke="currentColor" fill="none"/>
            <ellipse cx="12" cy="12" rx="3" ry="6" stroke="currentColor" fill="none" transform="rotate(60 12 12)"/>
            <ellipse cx="12" cy="12" rx="3" ry="6" stroke="currentColor" fill="none" transform="rotate(120 12 12)"/>
            <circle cx="18" cy="12" r="1.5" stroke="currentColor" fill="none"/>
            <circle cx="9" cy="17.2" r="1.5" stroke="currentColor" fill="none"/>
            <circle cx="15" cy="6.8" r="1.5" stroke="currentColor" fill="none"/>
        </svg>`;
    }

    // DETECT CASE ID FROM URL ──────────────────────────────────────────────
    function detectCaseId() {
        const caseIdParam = new URLSearchParams(window.location.search).get('caseId');
        if (caseIdParam) return caseIdParam;

        const idParam = new URLSearchParams(window.location.search).get('id');
        if (idParam) return idParam;

        const entityIdParam = new URLSearchParams(window.location.search).get('entityId');
        if (entityIdParam) {
            const entityIdMatch = entityIdParam.match(/^(\d+)/);
            if (entityIdMatch) return entityIdMatch[1];
        }

        const pathMatch = window.location.href.match(/\/(cases|investigation|view-case)\/([A-Z0-9\-]+)/i);
        if (pathMatch) return pathMatch[2];

        return 'UNKNOWN-' + Date.now();
    }

    // DETECT CASE TYPE FROM URL & QUEUE NAME ───────────────────────────────
    function detectCaseType() {
        const bodyText = document.body ? (document.body.innerText || '') : '';
        const queuePatterns = [
            /Queue[:\s]+([^\r\n]+)/i,
            /Queue Name[:\s]+([^\r\n]+)/i,
            /Assigned Queue[:\s]+([^\r\n]+)/i
        ];
        let queueName = '';
        for (const pattern of queuePatterns) {
            const match = bodyText.match(pattern);
            if (match) { queueName = match[1].trim(); break; }
        }
        currentQueueName = queueName;

        if (PHOTON_URL_PATTERN.test(window.location.href)) {
            currentCaseType = 'photon';
            if (!currentQueueName) currentQueueName = '(Photon - auto-detected from URL)';
        }
        else if (PHOTON_QUEUE_PATTERN.test(currentQueueName)) {
            currentCaseType = 'photon';
        }
        else if (EMAIL_QUEUE_PATTERN.test(currentQueueName)) {
            currentCaseType = 'email';
        }
        else {
            currentCaseType = 'nonemail';
        }

        return currentCaseType;
    }

    // FORMAT TIME ──────────────────────────────────────────────────────────
    function formatTime(seconds) {
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = (seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
    }

    function secondsToMinutes(seconds) {
        return parseFloat((seconds / 60).toFixed(2));
    }

    // DAG ACHIEVEMENT ──────────────────────────────────────────────────────
    function calcDAG(actualSeconds, caseType) {
        if (actualSeconds === 0) return null;
        return ((AHT_GOALS[caseType] / actualSeconds) * 100).toFixed(1);
    }

    // WEIGHTED STATS ───────────────────────────────────────────────────────
    function calcWeightedStats(log) {
        if (log.length === 0) return null;

        let emailCount = 0, nonEmailCount = 0, photonCount = 0;
        let emailTotal = 0, nonEmailTotal = 0, photonTotal = 0;

        for (const entry of log) {
            if (entry.caseType === 'email') {
                emailCount++;
                emailTotal += entry.duration;
            } else if (entry.caseType === 'photon') {
                photonCount++;
                photonTotal += entry.duration;
            } else {
                nonEmailCount++;
                nonEmailTotal += entry.duration;
            }
        }

        const totalCases = emailCount + nonEmailCount + photonCount;
        const emailWeight = emailCount / totalCases;
        const nonEmailWeight = nonEmailCount / totalCases;
        const photonWeight = photonCount / totalCases;

        const avgEmailAHT = emailCount > 0 ? emailTotal / emailCount : 0;
        const avgNonEmailAHT = nonEmailCount > 0 ? nonEmailTotal / nonEmailCount : 0;
        const avgPhotonAHT = photonCount > 0 ? photonTotal / photonCount : 0;
        const emailDAG = emailCount > 0 ? ((AHT_GOALS.email / avgEmailAHT) * 100).toFixed(1) : null;
        const nonEmailDAG = nonEmailCount > 0 ? ((AHT_GOALS.nonemail / avgNonEmailAHT) * 100).toFixed(1) : null;
        const photonDAG = photonCount > 0 ? ((AHT_GOALS.photon / avgPhotonAHT) * 100).toFixed(1) : null;

        const weightedGoalAHT = (AHT_GOALS.email * emailWeight) + (AHT_GOALS.nonemail * nonEmailWeight) + (AHT_GOALS.photon * photonWeight);
        const weightedAchievedAHT = (avgEmailAHT * emailWeight) + (avgNonEmailAHT * nonEmailWeight) + (avgPhotonAHT * photonWeight);
        const weightedDAG = weightedAchievedAHT > 0
            ? ((weightedGoalAHT / weightedAchievedAHT) * 100).toFixed(1)
            : null;

        const totalGoalAHT = (AHT_GOALS.email * emailCount) + (AHT_GOALS.nonemail * nonEmailCount) + (AHT_GOALS.photon * photonCount);
        const totalAchievedAHT = emailTotal + nonEmailTotal + photonTotal;

        return {
            weightedDAG, weightedGoalAHT, weightedAchievedAHT, totalGoalAHT, totalAchievedAHT, totalCases,
            emailCount, nonEmailCount, photonCount,
            avgEmail: avgEmailAHT, avgNonEmail: avgNonEmailAHT, avgPhoton: avgPhotonAHT,
            emailDAG, nonEmailDAG, photonDAG
        };
    }

    // EXCEL EXPORT ─────────────────────────────────────────────────────────
    function exportToExcel() {
        const log = JSON.parse(GM_getValue(STORAGE_KEY, '[]'));
        if (log.length === 0) { alert('No cases logged yet. Nothing to export.'); return; }

        const stats = calcWeightedStats(log);
        const wb    = XLSX.utils.book_new();

        const caseRows = log.map((entry, idx) => ({
            '#': idx + 1,
            'Case ID': entry.caseId,
            'Case Type': entry.caseType === 'email' ? 'Email' : entry.caseType === 'photon' ? 'Photon Fallback' : 'Non-Email',
            'Queue Name': entry.queueName || 'N/A',
            'Start Time': entry.startTime  ? new Date(entry.startTime).toLocaleString()  : 'N/A',
            'End Time': entry.timestamp  ? new Date(entry.timestamp).toLocaleString()  : 'N/A',
            'AHT (mm:ss)': entry.formatted,
            'AHT (minutes)': secondsToMinutes(entry.duration),
            'Goal (minutes)': secondsToMinutes(entry.goal),
            'DAG %': parseFloat(entry.dag),
            'DAG Status': parseFloat(entry.dag) >= 100 ? 'Achieved' : parseFloat(entry.dag) >= 80 ? 'Near Goal' : 'Below Goal'
        }));
        const ws1 = XLSX.utils.json_to_sheet(caseRows);
        ws1['!cols'] = [{wch:4},{wch:18},{wch:16},{wch:28},{wch:22},{wch:22},{wch:12},{wch:14},{wch:14},{wch:10},{wch:14}];
        XLSX.utils.book_append_sheet(wb, ws1, 'Case Log');

        const summaryRows = [
            { 'Metric': 'Export Date', 'Value': new Date().toLocaleString() },
            { 'Metric': '', 'Value': '' },
            { 'Metric': '── OVERALL (CASE-COUNT WEIGHTED) ──', 'Value': '' },
            { 'Metric': 'Total Cases', 'Value': stats.totalCases },
            { 'Metric': 'Email Cases', 'Value': stats.emailCount },
            { 'Metric': 'Non-Email Cases', 'Value': stats.nonEmailCount },
            { 'Metric': 'Photon Fallback Cases', 'Value': stats.photonCount },
            { 'Metric': 'Email Weight %', 'Value': stats.totalCases > 0 ? ((stats.emailCount / stats.totalCases) * 100).toFixed(1) + '%' : 'N/A' },
            { 'Metric': 'Non-Email Weight %', 'Value': stats.totalCases > 0 ? ((stats.nonEmailCount / stats.totalCases) * 100).toFixed(1) + '%' : 'N/A' },
            { 'Metric': 'Photon Weight %', 'Value': stats.totalCases > 0 ? ((stats.photonCount / stats.totalCases) * 100).toFixed(1) + '%' : 'N/A' },
            { 'Metric': '', 'Value': '' },
            { 'Metric': 'Weighted Goal AHT (min)', 'Value': secondsToMinutes(stats.weightedGoalAHT) },
            { 'Metric': 'Weighted Achieved AHT (min)', 'Value': secondsToMinutes(stats.weightedAchievedAHT) },
            { 'Metric': 'Weighted DAG %', 'Value': parseFloat(stats.weightedDAG) },
            { 'Metric': 'Weighted DAG Status', 'Value': parseFloat(stats.weightedDAG) >= 100 ? 'Achieved ✓' : 'Below Goal ✗' },
            { 'Metric': '', 'Value': '' },
            { 'Metric': 'Total Goal AHT (by case count)', 'Value': secondsToMinutes(stats.totalGoalAHT) },
            { 'Metric': 'Total Achieved AHT (by case count)', 'Value': secondsToMinutes(stats.totalAchievedAHT) },
            { 'Metric': '', 'Value': '' },
            { 'Metric': '── EMAIL CASES ──', 'Value': '' },
            { 'Metric': 'Email Goal (min)', 'Value': 4.5 },
            { 'Metric': 'Avg Email AHT (min)', 'Value': stats.avgEmail    !== 0 ? secondsToMinutes(stats.avgEmail)    : 'N/A' },
            { 'Metric': 'Email DAG %', 'Value': stats.emailDAG    !== null ? parseFloat(stats.emailDAG)          : 'N/A' },
            { 'Metric': 'Email DAG Status', 'Value': stats.emailDAG    !== null ? (parseFloat(stats.emailDAG)    >= 100 ? 'Achieved ✓' : 'Below Goal ✗') : 'N/A' },
            { 'Metric': '', 'Value': '' },
            { 'Metric': '── NON-EMAIL CASES ──', 'Value': '' },
            { 'Metric': 'Non-Email Goal (min)', 'Value': 8.0 },
            { 'Metric': 'Avg Non-Email AHT (min)', 'Value': stats.avgNonEmail !== 0 ? secondsToMinutes(stats.avgNonEmail) : 'N/A' },
            { 'Metric': 'Non-Email DAG %', 'Value': stats.nonEmailDAG !== null ? parseFloat(stats.nonEmailDAG)       : 'N/A' },
            { 'Metric': 'Non-Email DAG Status', 'Value': stats.nonEmailDAG !== null ? (parseFloat(stats.nonEmailDAG) >= 100 ? 'Achieved ✓' : 'Below Goal ✗') : 'N/A' },
            { 'Metric': '', 'Value': '' },
            { 'Metric': '── PHOTON FALLBACK CASES ──', 'Value': '' },
            { 'Metric': 'Photon Goal (min)', 'Value': 8.0 },
            { 'Metric': 'Avg Photon AHT (min)', 'Value': stats.avgPhoton !== 0 ? secondsToMinutes(stats.avgPhoton) : 'N/A' },
            { 'Metric': 'Photon DAG %', 'Value': stats.photonDAG !== null ? parseFloat(stats.photonDAG)       : 'N/A' },
            { 'Metric': 'Photon DAG Status', 'Value': stats.photonDAG !== null ? (parseFloat(stats.photonDAG) >= 100 ? 'Achieved ✓' : 'Below Goal ✗') : 'N/A' }
        ];
        const ws2 = XLSX.utils.json_to_sheet(summaryRows);
        ws2['!cols'] = [{wch:35},{wch:25}];
        XLSX.utils.book_append_sheet(wb, ws2, 'Summary');

        XLSX.writeFile(wb, `AHT_Log_${new Date().toISOString().slice(0,10)}.xlsx`);
    }

    // BUTTON STYLE HELPER ──────────────────────────────────────────────────
    function btnStyle(bg, large = false) {
        if (large) {
            return `background:${bg};color:#fff;border:none;border-radius:8px;padding:12px 14px;cursor:pointer;font-size:13px;font-weight:bold;flex:1;`;
        }
        return `background:${bg};color:#fff;border:none;border-radius:6px;padding:5px 9px;cursor:pointer;font-size:11px;font-weight:bold;`;
    }

    // LOAD POSITION AND SIZE ───────────────────────────────────────────────
    function loadPanelState() {
        const position = JSON.parse(GM_getValue(POSITION_STORAGE_KEY, '{"bottom":"20px","right":"20px"}'));
        const size = JSON.parse(GM_getValue(SIZE_STORAGE_KEY, '{"width":"260px","height":"auto"}'));
        return { position, size };
    }

    // SAVE POSITION AND SIZE ───────────────────────────────────────────────
    function savePanelState(panel) {
        const rect = panel.getBoundingClientRect();
        const position = {
            bottom: `${window.innerHeight - rect.bottom}px`,
            right: `${window.innerWidth - rect.right}px`,
            top: 'auto',
            left: 'auto'
        };
        const size = {
            width: `${rect.width}px`,
            height: `${rect.height}px`
        };
        GM_setValue(POSITION_STORAGE_KEY, JSON.stringify(position));
        GM_setValue(SIZE_STORAGE_KEY, JSON.stringify(size));
    }

    // BUILD UI PANEL ───────────────────────────────────────────────────────
    function buildPanel() {
        // Kill all duplicates first
        nukeAllDuplicates();

        panelBuildAttempts++;
        if (panelBuildAttempts > 3) {
            console.error('❌ Failed to build panel after 3 attempts. Check for conflicting scripts!');
            return;
        }

        const existing = document.getElementById('aht-tracker-panel');
        if (existing && document.body && document.body.contains(existing)) {
            console.log('✅ Panel already exists.');
            return;
        }
        if (existing) existing.remove();
        if (!document.body) return;

        const { position, size } = loadPanelState();

        const panel = document.createElement('div');
