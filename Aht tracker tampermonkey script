        panel.style.cssText = `
            position:fixed; bottom:${position.bottom}; right:${position.right};
            width:${size.width}; height:${size.height};
            background:#1a1a2e; color:#eaeaea; border-radius:12px;
            padding:14px 16px; font-family:Arial,sans-serif; font-size:13px;
            box-shadow:0 4px 20px rgba(0,0,0,0.5); z-index:99999; user-select:none;
            overflow-y:auto; overflow-x:hidden;
        `;

        panel.innerHTML = `
            <div id="aht-panel-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;cursor:move;padding:4px 0;border-bottom:1px solid #333;">
                <strong style="font-size:14px;">⏱ AHT Tracker</strong>
                <span id="aht-case-type-badge" style="font-size:10px;font-weight:bold;padding:2px 7px;border-radius:10px;background:#2980b9;color:#fff;">Non-Email</span>
            </div>
            <div id="aht-case-label" style="font-size:10px;color:#aaa;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                Case: ${currentCaseId}
            </div>
            <div id="aht-queue-label" style="font-size:10px;color:#888;margin-bottom:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                Queue: detecting...
            </div>
            <div id="aht-timer-display" style="font-size:32px;font-weight:bold;text-align:center;letter-spacing:2px;color:#00d4ff;margin:6px 0;">
                00:00
            </div>
            <div id="aht-goal-label" style="text-align:center;font-size:10px;color:#888;margin-bottom:4px;">
                Goal: 8:00 (Non-Email)
            </div>
            <div id="aht-status-bar" style="height:6px;border-radius:4px;background:#00d4ff;width:0%;transition:width 0.5s,background 0.5s;margin-bottom:8px;"></div>
            <div id="aht-dag-display" style="text-align:center;font-size:12px;color:#aaa;margin-bottom:8px;">DAG: —</div>
            <div id="aht-status-msg" style="text-align:center;font-size:11px;color:#aaa;margin-bottom:10px;">Press Start to begin tracking</div>

            <div style="display:flex;gap:8px;justify-content:center;margin-bottom:8px;">
                <button id="aht-btn-start" style="${btnStyle('#27ae60', true)}">▶ START</button>
                <button id="aht-btn-stop"  style="${btnStyle('#e74c3c', true)}" disabled>⏹ STOP</button>
            </div>
            <div style="display:flex;gap:6px;justify-content:center;margin-bottom:8px;">
                <button id="aht-btn-override-email"    style="${btnStyle('#8e44ad')}">📧 Email</button>
                <button id="aht-btn-override-nonemail" style="${btnStyle('#2c3e50')}">📁 Non-Email</button>
                <button id="aht-btn-override-photon"   style="${btnStyle('#c0392b')}">Photon</button>
            </div>
            <div style="display:flex;gap:6px;justify-content:center;margin-bottom:6px;">
                <button id="aht-btn-log"   style="${btnStyle('#2980b9')}">📋 View Log</button>
                <button id="aht-btn-help"  style="${btnStyle('#16a085')}">❓ Help</button>
            </div>
            <div style="display:flex;gap:6px;justify-content:center;margin-bottom:6px;">
                <button id="aht-btn-clear" style="${btnStyle('#7f8c8d')}">🗑 Clear</button>
                <button id="aht-btn-export" style="${btnStyle('#27ae60')}">📥 Export</button>
            </div>
            <div id="aht-log-panel" style="display:none;margin-top:10px;max-height:300px;overflow-y:auto;background:#0f0f1a;border-radius:8px;padding:8px;font-size:11px;color:#ccc;"></div>
            <div id="aht-help-panel" style="display:none;margin-top:10px;max-height:300px;overflow-y:auto;background:#0f0f1a;border-radius:8px;padding:12px;font-size:11px;color:#ddd;line-height:1.6;"></div>

            <div id="aht-resize-handle" style="position:absolute;bottom:0;right:0;width:16px;height:16px;cursor:nwse-resize;background:linear-gradient(135deg, transparent 50%, #00d4ff 50%);border-radius:0 0 12px 0;opacity:0.3;"></div>
