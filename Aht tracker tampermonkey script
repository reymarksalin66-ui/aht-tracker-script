            }
        `;
        document.head.appendChild(style);

        setTimeout(() => {
            const photonBtn = document.getElementById('aht-btn-override-photon');
            if (photonBtn) {
                photonBtn.innerHTML = getAtomSVG() + 'Photon';
            }
        }, 100);

        attachEvents();
        attachDragResize();
        refreshCaseType();
    }

    // DRAG AND RESIZE HANDLERS ─────────────────────────────────────────────
    function attachDragResize() {
        const panel = document.getElementById('aht-tracker-panel');
        const header = document.getElementById('aht-panel-header');
        const resizeHandle = document.getElementById('aht-resize-handle');

        if (!panel || !header) return;

        header.addEventListener('mousedown', (e) => {
            isDragging = true;
            dragOffsetX = e.clientX - panel.getBoundingClientRect().left;
            dragOffsetY = e.clientY - panel.getBoundingClientRect().top;
            header.style.opacity = '0.7';
        });

        document.addEventListener('mousemove', (e) => {
            if (isDragging) {
                const newX = e.clientX - dragOffsetX;
                const newY = e.clientY - dragOffsetY;
                const rect = panel.getBoundingClientRect();
                const maxX = window.innerWidth - rect.width;
                const maxY = window.innerHeight - rect.height;
                panel.style.left = Math.max(0, Math.min(newX, maxX)) + 'px';
                panel.style.top = Math.max(0, Math.min(newY, maxY)) + 'px';
                panel.style.bottom = 'auto';
                panel.style.right = 'auto';
            }

            if (isResizing) {
                const newWidth = Math.max(220, resizeStartWidth + (e.clientX - resizeStartX));
                const newHeight = Math.max(300, resizeStartHeight + (e.clientY - resizeStartY));
                panel.style.width = newWidth + 'px';
                panel.style.height = newHeight + 'px';
            }
        });

        document.addEventListener('mouseup', (e) => {
            if (isDragging) {
                isDragging = false;
                header.style.opacity = '1';
                savePanelState(panel);
            }
            if (isResizing) {
                isResizing = false;
                resizeHandle.style.opacity = '0.3';
                savePanelState(panel);
            }
        });

        if (resizeHandle) {
            resizeHandle.addEventListener('mousedown', (e) => {
                e.preventDefault();
                isResizing = true;
                resizeStartX = e.clientX;
                resizeStartY = e.clientY;
                const rect = panel.getBoundingClientRect();
                resizeStartWidth = rect.width;
                resizeStartHeight = rect.height;
                resizeHandle.style.opacity = '1';
            });
        }

        header.addEventListener('touchstart', (e) => {
            if (e.touches.length !== 1) return;
            isDragging = true;
            dragOffsetX = e.touches[0].clientX - panel.getBoundingClientRect().left;
            dragOffsetY = e.touches[0].clientY - panel.getBoundingClientRect().top;
        });

        document.addEventListener('touchmove', (e) => {
            if (isDragging && e.touches.length === 1) {
                const newX = e.touches[0].clientX - dragOffsetX;
                const newY = e.touches[0].clientY - dragOffsetY;
                const rect = panel.getBoundingClientRect();
                const maxX = window.innerWidth - rect.width;
                const maxY = window.innerHeight - rect.height;
                panel.style.left = Math.max(0, Math.min(newX, maxX)) + 'px';
                panel.style.top = Math.max(0, Math.min(newY, maxY)) + 'px';
                panel.style.bottom = 'auto';
                panel.style.right = 'auto';
            }
        });

        document.addEventListener('touchend', () => {
            if (isDragging) {
                isDragging = false;
                savePanelState(panel);
            }
        });
    }

