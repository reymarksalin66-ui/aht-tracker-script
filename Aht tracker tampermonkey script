        let panel = document.getElementById('aht-tracker-panel');

        // Panel already exists and is in DOM
        if (panel && document.body && document.body.contains(panel)) {
            return panel;
        }

        // Remove old orphaned panel
        if (panel) panel.remove();

        // Wait for body if needed
        if (!document.body) {
            setTimeout(ensurePanelExists, 50);
            return null;
        }

        // Create new panel
        const { position, size } = loadPanelState();

        panel = document.createElement('div');
        panel.id = 'aht-tracker-panel';

        panel.innerHTML = `
            <div id="aht-resize-handle"></div>
