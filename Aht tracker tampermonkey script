    // ═════════════════════════════════════════════════════════════════════════
    // 🎯 GOALS MANAGEMENT
    // ═════════════════════════════════════════════════════════════════════════

    function loadGoals() {
        try {
            const stored = safeGetStorage(CONFIG.storage.goals, null);

            if (stored && typeof stored === 'object') {
                AHT_GOALS = {
                    email: Math.max(60, parseInt(stored.email) || CONFIG.defaults.email),
                    nonemail: Math.max(60, parseInt(stored.nonemail) || CONFIG.defaults.nonemail),
                    photon: Math.max(60, parseInt(stored.photon) || CONFIG.defaults.photon)
                };
                console.log('✅ Custom AHT goals loaded:', AHT_GOALS);
                return;
            }
        } catch (e) {
            console.error('❌ Error loading goals:', e);
        }

        AHT_GOALS = { ...CONFIG.defaults };
        console.log('ℹ️ Using default AHT goals');
    }

    function saveGoals() {
        const success = safeSetStorage(CONFIG.storage.goals, JSON.stringify(AHT_GOALS));
        if (success) {
            console.log('💾 AHT goals saved');
        }
    }

    function resetGoalsToDefault() {
        AHT_GOALS = { ...CONFIG.defaults };
        saveGoals();
        updateGoalsUI();
        updateCaseTypeUI();
        if (DOM.display) DOM.display.style.color = '#00d4ff';
        updateStatusMsg('✅ Goals reset', '#2ecc71');
    }

    // ═════════════════════════════════════════════════════════════════════════
    // 🧭 CASE DETECTION (v3.3.5 VIEW-CASE SUPPORT)
    // ═════════════════════════════════════════════════════════════════════════

    function detectCaseId() {
        const detectors = [
            // Check URL params first
            () => new URLSearchParams(window.location.search).get('caseId'),
            () => new URLSearchParams(window.location.search).get('id'),
            // Check entityId for Photon cases
            () => {
                const entityId = new URLSearchParams(window.location.search).get('entityId');
                if (entityId) {
                    const match = entityId.match(/^(\d+):/);
                    if (match) {
                        console.log(`✅ [PHOTON DETECTION] Case ID: ${match[1]} from entityId: ${entityId}`);
                        return match[1];
                    }
                }
                return null;
            },
            // Check URL path
            () => {
                const match = window.location.href.match(/\/(cases|investigation|view-case)\/([A-Z0-9\-]+)/i);
                return match ? match[2] : null;
            }
        ];

        for (const detector of detectors) {
            try {
                const result = detector();
                if (result && String(result).length > 3) {
                    console.log(`✅ [CASE DETECTION] Found Case ID: ${result}`);
                    return String(result).substring(0, 100);
                }
            } catch (e) {
                console.warn('⚠️ Case detection error:', e);
            }
        }

        const fallbackId = `UNKNOWN-${Date.now()}`;
        console.warn(`⚠️ [CASE DETECTION] No case ID found, using fallback: ${fallbackId}`);
        return fallbackId;
    }

    function detectCaseType() {
        const entityType = new URLSearchParams(window.location.search).get('entityType');
        if (entityType === 'UnitOfWork') {
            currentCaseType = 'photon';
            currentQueueName = 'Photon Fallback (UnitOfWork)';
            console.log('✅ [CASE TYPE] UnitOfWork detected - PHOTON');
            return currentCaseType;
        }

        const bodyText = document.body ? (document.body.innerText || '') : '';
        const queuePatterns = [
            /Queue[:\s]+([^\r\n]+)/i,
            /Queue Name[:\s]+([^\r\n]+)/i,
            /Assigned Queue[:\s]+([^\r\n]+)/i
        ];

        let queueName = '';
        for (const pattern of queuePatterns) {
            const match = bodyText.match(pattern);
            if (match) {
                queueName = match[1].trim().substring(0, 200);
                break;
            }
        }
        currentQueueName = queueName;

        if (CONFIG.patterns.photon.test(currentQueueName)) {
            currentCaseType = 'photon';
            console.log('✅ [CASE TYPE] Queue matches PHOTON pattern:', currentQueueName);
        } else if (CONFIG.patterns.email.test(currentQueueName)) {
            currentCaseType = 'email';
            console.log('✅ [CASE TYPE] Queue matches EMAIL pattern:', currentQueueName);
        } else {
            currentCaseType = 'nonemail';
            console.log('✅ [CASE TYPE] Defaulting to NON-EMAIL. Queue:', currentQueueName);
        }

        return currentCaseType;
    }

    // ═════════════════════════════════════════════════════════════════════════
    // ⏱ TIME FORMATTING & CALCULATIONS
    // ═════════════════════════════════════════════════════════════════════════

    function formatTime(seconds) {
        seconds = Math.max(0, parseInt(seconds) || 0);
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = (seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
    }

    function secondsToMinutes(seconds) {
        return parseFloat((Math.max(0, parseInt(seconds) || 0) / 60).toFixed(2));
    }

    function calcDAG(actualSeconds, caseType) {
        if (actualSeconds === 0) return null;
        const dag = ((AHT_GOALS[caseType] / actualSeconds) * 100);
        return Math.min(999.9, dag).toFixed(1);
    }

    function calcWeightedStats(log) {
        if (!Array.isArray(log) || log.length === 0) return null;

        const excluded = loadExcludedEntries();

        const filteredLog = log.filter(entry => {
            const key = getEntryKey(entry.caseId, entry.timestamp);
            return !excluded.includes(key);
        });

        if (filteredLog.length === 0) {
            console.warn('⚠️ All entries excluded');
            return null;
        }

        let emailCount = 0, nonEmailCount = 0, photonCount = 0;
        let emailTotal = 0, nonEmailTotal = 0, photonTotal = 0;

        for (const entry of filteredLog) {
            try {
                const duration = Math.max(0, parseInt(entry.duration) || 0);

                if (entry.caseType === 'email') {
                    emailCount++;
                    emailTotal += duration;
                } else if (entry.caseType === 'photon') {
                    photonCount++;
                    photonTotal += duration;
                } else {
                    nonEmailCount++;
                    nonEmailTotal += duration;
                }
            } catch (e) {
                console.warn('⚠️ Error processing entry:', e);
            }
        }

        const totalCases = emailCount + nonEmailCount + photonCount;
        if (totalCases === 0) return null;

        const emailWeight = emailCount / totalCases;
        const nonEmailWeight = nonEmailCount / totalCases;
        const photonWeight = photonCount / totalCases;

        const avgEmailAHT = emailCount > 0 ? emailTotal / emailCount : 0;
        const avgNonEmailAHT = nonEmailCount > 0 ? nonEmailTotal / nonEmailCount : 0;
        const avgPhotonAHT = photonCount > 0 ? photonTotal / photonCount : 0;

        const emailDAG = emailCount > 0 ? ((AHT_GOALS.email / avgEmailAHT) * 100).toFixed(1) : null;
        const nonEmailDAG = nonEmailCount > 0 ? ((AHT_GOALS.nonemail / avgNonEmailAHT) * 100).toFixed(1) : null;
        const photonDAG = photonCount > 0 ? ((AHT_GOALS.photon / avgPhotonAHT) * 100).toFixed(1) : null;

        const weightedGoalAHT = (AHT_GOALS.email * emailWeight) +
                                (AHT_GOALS.nonemail * nonEmailWeight) +
                                (AHT_GOALS.photon * photonWeight);
        const weightedAchievedAHT = (avgEmailAHT * emailWeight) +
                                    (avgNonEmailAHT * nonEmailWeight) +
                                    (avgPhotonAHT * photonWeight);
        const weightedDAG = weightedAchievedAHT > 0
            ? ((weightedGoalAHT / weightedAchievedAHT) * 100).toFixed(1)
            : null;

        return {
            weightedDAG, weightedGoalAHT, weightedAchievedAHT,
            totalCases,
            emailCount, nonEmailCount, photonCount,
            avgEmail: avgEmailAHT,
            avgNonEmail: avgNonEmailAHT,
            avgPhoton: avgPhotonAHT,
            emailDAG, nonEmailDAG, photonDAG,
            excludedCount: log.length - filteredLog.length
        };
    }

    // ═════════════════════════════════════════════════════════════════════════
    // ⭐ TIMER MANAGEMENT (NO MEMORY LEAKS)
    // ═════════════════════════════════════════════════════════════════════════

    function startTimer() {
        if (isRunning) return;

        if (timerInterval !== null) {
            clearInterval(timerInterval);
            timerInterval = null;
        }

        refreshCaseType();
        isRunning = true;
        caseStartTimestamp = new Date().toISOString();
        startTime = Date.now() - (elapsedSeconds * 1000);

        timerInterval = setInterval(() => {
            try {
                elapsedSeconds = Math.floor((Date.now() - startTime) / 1000);
                updateDisplay();
                saveTimerState();
            } catch (e) {
                console.error('❌ Timer error:', e);
            }
        }, CONFIG.timers.updateFrequency);

        registerCleanup(() => {
            if (timerInterval !== null) {
                clearInterval(timerInterval);
                timerInterval = null;
            }
        });

        setButtonStates(true);
        updateStatusMsg('🟢 Tracking...', '#2ecc71');
        saveTimerState();
        console.log('✅ Timer started');
    }

    function stopTimer() {
        if (timerInterval !== null) {
            clearInterval(timerInterval);
            timerInterval = null;
        }

        isRunning = false;
        const dag = calcDAG(elapsedSeconds, currentCaseType);
        saveLog(dag);

        manuallyStoppedOnCase = currentCaseId;
        stoppedAtZero = (elapsedSeconds === 0);

        updateStatusMsg(`✅ Saved | DAG: ${dag}%`, '#00d4ff');
        setButtonStates(false);
        saveTimerState();

        elapsedSeconds = 0;
        caseStartTimestamp = null;

        if (DOM.display) {
            DOM.display.textContent = '00:00';
            DOM.display.style.color = '#00d4ff';
        }
        if (DOM.bar) {
            DOM.bar.style.width = '0%';
            DOM.bar.style.background = '#00d4ff';
        }
        if (DOM.dag) DOM.dag.textContent = 'DAG: —';

        updateStatusMsg('⏸ Timer paused', '#aaa');
        console.log(`🛑 Timer stopped`);
    }

    // ═════════════════════════════════════════════════════════════════════════
    // 💾 TIMER STATE PERSISTENCE
    // ═════════════════════════════════════════════════════════════════════════

    function saveTimerState() {
        const timerState = {
            isRunning: isRunning,
            startTime: startTime,
            caseId: currentCaseId,
            caseType: currentCaseType,
            queueName: currentQueueName,
            caseStartTimestamp: caseStartTimestamp,
            stoppedAtZero: stoppedAtZero,
            savedAt: Date.now()
        };
        safeSetStorage(CONFIG.storage.timer, JSON.stringify(timerState));
    }

    function restoreTimerState() {
        try {
            const timerState = safeGetStorage(CONFIG.storage.timer, null);

            if (!timerState) {
                console.log('ℹ️ No saved timer state');
                return false;
            }

            if (timerState.caseId !== currentCaseId) {
                safeSetStorage(CONFIG.storage.timer, JSON.stringify({ isRunning: false }));
                return false;
            }

            if (timerState.stoppedAtZero === true) {
                safeSetStorage(CONFIG.storage.timer, JSON.stringify({ isRunning: false }));
                shouldAutoStartOnLoad = false;
                return false;
            }

            if (timerState.isRunning && timerState.startTime) {
                const calculatedElapsed = Math.floor((Date.now() - timerState.startTime) / 1000);

                startTime = timerState.startTime;
                elapsedSeconds = calculatedElapsed;
                isRunning = true;
                currentCaseId = timerState.caseId;
                currentCaseType = timerState.caseType;
                currentQueueName = timerState.queueName;
                caseStartTimestamp = timerState.caseStartTimestamp;
                stoppedAtZero = false;
                shouldAutoStartOnLoad = false;

                console.log(`✅ Timer restored: ${formatTime(elapsedSeconds)}`);
                return true;
            }
        } catch (e) {
            console.error('❌ Error restoring timer:', e);
        }
        return false;
    }

