    // REFRESH CASE TYPE UI ─────────────────────────────────────────────────
    function refreshCaseType() {
        detectCaseType();
        updateCaseTypeUI();
    }

    function updateCaseTypeUI() {
        const badge      = document.getElementById('aht-case-type-badge');
        const goalLabel  = document.getElementById('aht-goal-label');
        const queueLabel = document.getElementById('aht-queue-label');
        if (!badge) return;
        if (currentCaseType === 'email') {
            badge.textContent = 'Email';
            badge.style.background = '#8e44ad';
            if (goalLabel) goalLabel.textContent = 'Goal: 4:30 (Email)';
        } else if (currentCaseType === 'photon') {
            badge.textContent = 'Photon Fallback';
            badge.style.background = '#c0392b';
            if (goalLabel) goalLabel.textContent = 'Goal: 8:00 (Photon)';
        } else {
            badge.textContent = 'Non-Email';
            badge.style.background = '#2980b9';
            if (goalLabel) goalLabel.textContent = 'Goal: 8:00 (Non-Email)';
        }
        if (queueLabel) queueLabel.textContent = currentQueueName ? `Queue: ${currentQueueName}` : 'Queue: not detected';
    }

    // TIMER LOGIC ──────────────────────────────────────────────────────────
    function startTimer() {
        if (isRunning) return;
        refreshCaseType();
        isRunning = true;
        caseStartTimestamp = new Date().toISOString();
        startTime = Date.now() - (elapsedSeconds * 1000);
        timerInterval = setInterval(() => {
            elapsedSeconds = Math.floor((Date.now() - startTime) / 1000);
            updateDisplay();
        }, 1000);
        setButtonStates(true);
        updateStatusMsg('🟢 Tracking...', '#2ecc71');
    }

    function stopTimer() {
        clearInterval(timerInterval);
        isRunning = false;
        const dag = calcDAG(elapsedSeconds, currentCaseType);
        saveLog(dag);
        updateStatusMsg(`✅ Saved | DAG: ${dag}%`, '#00d4ff');
        setButtonStates(false);
        const startBtn = document.getElementById('aht-btn-start');
        if (startBtn) startBtn.disabled = true;

        setTimeout(() => {
            elapsedSeconds = 0;
            caseStartTimestamp = null;
            currentCaseId = detectCaseId();
            const display    = document.getElementById('aht-timer-display');
            const bar        = document.getElementById('aht-status-bar');
            const caseLabel  = document.getElementById('aht-case-label');
            const dagDisplay = document.getElementById('aht-dag-display');
            const btn        = document.getElementById('aht-btn-start');
            if (display)    { display.textContent = '00:00'; display.style.color = '#00d4ff'; }
            if (bar)        { bar.style.width = '0%'; bar.style.background = '#00d4ff'; }
            if (caseLabel)  caseLabel.textContent = `Case: ${currentCaseId}`;
            if (dagDisplay) dagDisplay.textContent = 'DAG: —';
            if (btn)        btn.disabled = false;
            updateStatusMsg('Press Start to begin tracking', '#aaa');
            refreshCaseType();
        }, 3000);
    }

    // DISPLAY UPDATE ───────────────────────────────────────────────────────
    function updateDisplay() {
        const display    = document.getElementById('aht-timer-display');
        const bar        = document.getElementById('aht-status-bar');
        const dagDisplay = document.getElementById('aht-dag-display');
        if (!display || !bar) return;

        const goal = AHT_GOALS[currentCaseType];
        display.textContent = formatTime(elapsedSeconds);

        const pct = Math.min((elapsedSeconds / goal) * 100, 100);
        bar.style.width = pct + '%';

        const dag = calcDAG(elapsedSeconds, currentCaseType);
        if (dag !== null && dagDisplay) {
            const dagVal   = parseFloat(dag);
            const dagColor = dagVal >= 100 ? '#2ecc71' : dagVal >= 80 ? '#f39c12' : '#e74c3c';
            dagDisplay.textContent = `DAG: ${dag}%`;
            dagDisplay.style.color = dagColor;
        }

        const warningAt = goal * 0.75;
        if (elapsedSeconds >= goal) {
            display.style.color = '#e74c3c';
            bar.style.background = '#e74c3c';
            updateStatusMsg('🚨 AHT Critical! Wrap up now.', '#e74c3c');
            if (elapsedSeconds === Math.floor(goal)) triggerNotification('critical');
        } else if (elapsedSeconds >= warningAt) {
            display.style.color = '#f39c12';
            bar.style.background = '#f39c12';
            updateStatusMsg('⚠️ Approaching AHT goal', '#f39c12');
            if (elapsedSeconds === Math.floor(warningAt)) triggerNotification('warning');
        } else {
            display.style.color = '#00d4ff';
            bar.style.background = '#00d4ff';
            updateStatusMsg('🟢 Tracking...', '#2ecc71');
        }
    }

    function updateStatusMsg(msg, color = '#aaa') {
        const el = document.getElementById('aht-status-msg');
        if (el) { el.textContent = msg; el.style.color = color; }
    }

    // NOTIFICATIONS ────────────────────────────────────────────────────────
    function triggerNotification(level) {
        const typeLabel = currentCaseType === 'email' ? 'Email' : currentCaseType === 'photon' ? 'Photon Fallback' : 'Non-Email';
        const goalStr = currentCaseType === 'email' ? '4.5 min' : '8 min';
        const messages = {
            warning:  { title: '⚠️ AHT Warning',  text: `Case ${currentCaseId} (${typeLabel}): 75% of ${goalStr} goal reached.` },
            critical: { title: '🚨 AHT Critical', text: `Case ${currentCaseId} (${typeLabel}): Goal of ${goalStr} exceeded!` }
        };
        GM_notification({ title: messages[level].title, text: messages[level].text, timeout: 5000 });
    }

    // LOGGING ──────────────────────────────────────────────────────────────
    function saveLog(dag) {
        const log = JSON.parse(GM_getValue(STORAGE_KEY, '[]'));
        log.push({
            caseId:    currentCaseId,
            caseType:  currentCaseType,
            queueName: currentQueueName,
            duration:  elapsedSeconds,
            formatted: formatTime(elapsedSeconds),
            goal:      AHT_GOALS[currentCaseType],
            dag:       dag,
            startTime: caseStartTimestamp,
            timestamp: new Date().toISOString()
        });
        GM_setValue(STORAGE_KEY, JSON.stringify(log));
    }

    function renderLog() {
        const logPanel = document.getElementById('aht-log-panel');
        if (!logPanel) return;
        const log = JSON.parse(GM_getValue(STORAGE_KEY, '[]'));
        if (log.length === 0) { logPanel.innerHTML = '<em>No cases logged yet.</em>'; return; }

        const stats    = calcWeightedStats(log);
        const dagColor = (dag) => { const v = parseFloat(dag); return v >= 100 ? '#2ecc71' : v >= 80 ? '#f39c12' : '#e74c3c'; };

        const rows = log.slice(-10).reverse().map(entry => {
            const typeLabel = entry.caseType === 'email' ? 'Email' : entry.caseType === 'photon' ? 'Photon' : 'Non-Email';
            const typeBg = entry.caseType === 'email' ? '#8e44ad' : entry.caseType === 'photon' ? '#c0392b' : '#2980b9';
            return `
                <div style="border-bottom:1px solid #222;padding:4px 0;">
                    <span style="font-weight:bold;">${entry.caseId}</span>
                    <span style="font-size:9px;padding:1px 5px;border-radius:8px;background:${typeBg};color:#fff;margin-left:4px;">
                        ${typeLabel}
                    </span><br>
                    ⏱ ${entry.formatted} &nbsp;|&nbsp;
                    <span style="color:${dagColor(entry.dag)}">DAG: ${entry.dag}%</span> &nbsp;|&nbsp;
                    🕐 ${new Date(entry.timestamp).toLocaleTimeString()}
                </div>
            `;
        }).join('');

        logPanel.innerHTML = `
            <div style="background:#16213e;border-radius:6px;padding:8px;margin-bottom:8px;font-size:11px;">
                <div style="color:#00d4ff;font-weight:bold;margin-bottom:4px;">📊 Session Summary</div>
                <div style="color:#aaa;"><strong style="color:#fff;">Total: ${stats.totalCases}</strong> (📧${stats.emailCount}|📁${stats.nonEmailCount}|⚛${stats.photonCount})</div>
                <div style="color:#aaa;">Weighted DAG: <strong style="color:${parseFloat(stats.weightedDAG) >= 100 ? '#2ecc71' : '#f39c12'}">${stats.weightedDAG}%</strong></div>
            </div>
            ${rows}
        `;
    }

    // BUTTON STATES ────────────────────────────────────────────────────────
    function setButtonStates(running) {
        const s = document.getElementById('aht-btn-start');
        const x = document.getElementById('aht-btn-stop');
        if (s) s.disabled = running;
        if (x) x.disabled = !running;
    }

    // EVENT LISTENERS ──────────────────────────────────────────────────────
    function attachEvents() {
        document.getElementById('aht-btn-start').addEventListener('click', startTimer);
        document.getElementById('aht-btn-stop').addEventListener('click', stopTimer);

        document.getElementById('aht-btn-override-email').addEventListener('click', () => {
            currentCaseType = 'email'; currentQueueName = '(manual override)';
            updateCaseTypeUI(); updateStatusMsg('📧 Set to Email manually', '#8e44ad');
        });
        document.getElementById('aht-btn-override-nonemail').addEventListener('click', () => {
            currentCaseType = 'nonemail'; currentQueueName = '(manual override)';
            updateCaseTypeUI(); updateStatusMsg('📁 Set to Non-Email manually', '#2980b9');
        });
        document.getElementById('aht-btn-override-photon').addEventListener('click', () => {
            currentCaseType = 'photon'; currentQueueName = '(manual override - Photon Fallback)';
            updateCaseTypeUI(); updateStatusMsg('⚛ Set to Photon Fallback manually', '#c0392b');
        });

        document.getElementById('aht-btn-log').addEventListener('click', () => {
            const lp = document.getElementById('aht-log-panel');
            if (!lp) return;
            const hp = document.getElementById('aht-help-panel');
            if (hp && hp.style.display === 'block') {
                hp.style.display = 'none';
                helpPanelOpen = false;
                const helpBtn = document.getElementById('aht-btn-help');
                if (helpBtn) helpBtn.style.opacity = '1';
            }
            if (lp.style.display === 'none') { renderLog(); lp.style.display = 'block'; }
            else lp.style.display = 'none';
        });

        document.getElementById('aht-btn-help').addEventListener('click', () => {
            const lp = document.getElementById('aht-log-panel');
            if (lp && lp.style.display === 'block') {
                lp.style.display = 'none';
            }
            displayHelpInstructions();
        });

        document.getElementById('aht-btn-clear').addEventListener('click', () => {
            if (confirm('Clear all AHT logs?')) {
                GM_setValue(STORAGE_KEY, '[]');
                const lp = document.getElementById('aht-log-panel');
                if (lp) lp.innerHTML = '<em>Log cleared.</em>';
            }
        });

        document.getElementById('aht-btn-export').addEventListener('click', exportToExcel);
    }

    // SPA NAVIGATION ───────────────────────────────────────────────────────
    let lastUrl = location.href;

    function schedulePanelRebuild() {
        if (rebuildTimeout) clearTimeout(rebuildTimeout);
        rebuildTimeout = setTimeout(() => {
            nukeAllDuplicates();
            if (!document.getElementById('aht-tracker-panel')) {
                buildPanel();
            }
        }, 500);
    }

    if (mutationObserver) mutationObserver.disconnect();

    mutationObserver = new MutationObserver(() => {
        nukeAllDuplicates();

        if (!document.getElementById('aht-tracker-panel')) {
            schedulePanelRebuild();
        }

        const url = location.href;
        if (url !== lastUrl) {
            lastUrl = url;
            currentCaseId = detectCaseId();
            if (isRunning) { clearInterval(timerInterval); isRunning = false; }
            elapsedSeconds = 0;
            caseStartTimestamp = null;

            const caseLabel  = document.getElementById('aht-case-label');
            const display    = document.getElementById('aht-timer-display');
            const bar        = document.getElementById('aht-status-bar');
            const dagDisplay = document.getElementById('aht-dag-display');

            if (caseLabel)  caseLabel.textContent = `Case: ${currentCaseId}`;
            if (display)    { display.textContent = '00:00'; display.style.color = '#00d4ff'; }
            if (bar)        { bar.style.width = '0%'; bar.style.background = '#00d4ff'; }
            if (dagDisplay) dagDisplay.textContent = 'DAG: —';

            updateStatusMsg('Press Start to begin tracking', '#aaa');
            setButtonStates(false);
            setTimeout(refreshCaseType, 1500);
        }
    });

    mutationObserver.observe(document, { subtree: true, childList: true });

    // INIT ─────────────────────────────────────────────────────────────────
    function tryBuildPanel() {
        if (document.body) {
            buildPanel();
        } else {
            setTimeout(tryBuildPanel, 200);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', tryBuildPanel);
    } else {
        tryBuildPanel();
    }

    // Cleanup
    window.addEventListener('beforeunload', () => {
        if (mutationObserver) mutationObserver.disconnect();
        if (timerInterval) clearInterval(timerInterval);
    });

    // Debug helper
    console.log('%c🔧 AHT Tracker Debug Helper', 'color: #00d4ff; font-weight: bold; font-size: 14px;');
    console.log(`%cInstance ID: ${SCRIPT_INSTANCE_ID}`, 'color: #2ecc71; font-size: 12px;');
    console.log('%cTo check for duplicates, run: window.__AHT_DEBUG__()', 'color: #f39c12; font-size: 11px;');

    window.__AHT_DEBUG__ = function() {
        console.log('=== AHT TRACKER DEBUG ===');
        console.log('Instance ID:', SCRIPT_INSTANCE_ID);
        console.log('Stored Instance:', sessionStorage.getItem(INSTANCE_STORAGE_KEY));
        console.log('Panels found:', document.querySelectorAll('[id*="aht-tracker-panel"]').length);
        console.log('Current Case:', currentCaseId);
        console.log('Current Type:', currentCaseType);
        console.log('======================');
    };
})();
