    function renderLog() {
        const logPanel = document.getElementById('aht-log-panel');
        if (!logPanel) return;

        const log = loadLogSafely();
        if (log.length === 0) {
            logPanel.innerHTML = '<em>No cases logged yet.</em>';
            return;
        }

        const excluded = loadExcludedEntries();
        const stats = calcWeightedStats(log);
        const duplicates = findDuplicateCases(log);

        const dagColor = (dag) => {
            const v = parseFloat(dag);
            return v >= 100 ? '#2ecc71' : v >= 80 ? '#f39c12' : '#e74c3c';
        };

        let duplicateWarning = '';
        if (duplicates.length > 0) {
            const totalDups = duplicates.reduce((sum, d) => sum + (d.count - 1), 0);
            duplicateWarning = `
                <div style="background:#c0392b;border-radius:6px;padding:8px;margin-bottom:8px;border-left:4px solid #e74c3c;">
                    <div style="color:#fff;font-size:11px;font-weight:bold;">⚠️ FOUND ${duplicates.length} DUPLICATE CASE(S) (${totalDups} extra)</div>
                    <button id="aht-btn-auto-exclude-dups" style="background:#f1c40f;color:#000;border:none;border-radius:4px;padding:6px 10px;cursor:pointer;font-size:10px;font-weight:bold;margin-top:4px;" title="Automatically exclude duplicate entries (keeps first instance)">🔄 Auto-Exclude Dups</button>
                </div>
            `;
        }

        const rows = log.slice(-15).reverse().map((entry) => {
            const key = getEntryKey(entry.caseId, entry.timestamp);
            const isExcluded = excluded.includes(key);
            const typeLabel = entry.caseType === 'email' ? 'Email' : entry.caseType === 'photon' ? 'Photon' : 'Non-Email';
            const typeBg = entry.caseType === 'email' ? '#8e44ad' : entry.caseType === 'photon' ? '#c0392b' : '#2980b9';

            const rowStyle = isExcluded
                ? 'border-bottom:1px solid #444;padding:4px 0;opacity:0.5;background:#0a0a14;'
                : 'border-bottom:1px solid #222;padding:4px 0;';

            const excludeBtn = `
                <button id="exclude-${entry.caseId}-${entry.timestamp}" style="background:${isExcluded ? '#27ae60' : '#e74c3c'};color:#fff;border:none;border-radius:4px;padding:2px 6px;cursor:pointer;font-size:9px;font-weight:bold;" title="Exclude this instance">
                    ${isExcluded ? '✓ Included' : '✗ Exclude'}
                </button>
            `;

            const deleteBtn = `
                <button id="delete-${entry.caseId}-${entry.timestamp}" style="background:#e74c3c;color:#fff;border:none;border-radius:4px;padding:2px 6px;cursor:pointer;font-size:9px;font-weight:bold;margin-left:2px;" title="Delete (30s undo)">
                    🗑 Delete
                </button>
            `;

            return `
                <div style="${rowStyle}">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2px;">
                        <div style="flex:1;">
                            <span style="font-weight:bold;${isExcluded ? 'text-decoration:line-through;' : ''}">${entry.caseId}</span>
                            <span style="font-size:9px;padding:1px 5px;border-radius:8px;background:${typeBg};color:#fff;margin-left:4px;">${typeLabel}</span>
                            ${isExcluded ? '<span style="font-size:9px;color:#e74c3c;margin-left:4px;">⊘ EXCLUDED</span>' : ''}
                        </div>
                        <div>
                            ${excludeBtn}
                            ${deleteBtn}
                        </div>
                    </div>
                    <div style="font-size:10px;color:#aaa;">
                        ⏱ ${entry.formatted} | <span style="color:${dagColor(entry.dag)}">DAG: ${entry.dag}%</span> | ${new Date(entry.timestamp).toLocaleTimeString()}
                    </div>
                </div>
            `;
        }).join('');

        setTimeout(() => {
            const autoDupBtn = document.getElementById('aht-btn-auto-exclude-dups');
            if (autoDupBtn) {
                autoDupBtn.addEventListener('click', () => {
                    if (autoExcludeDuplicates()) {
                        renderLog();
                        updateStatusMsg('✅ Duplicates excluded!', '#2ecc71');
                    }
                });
            }

            log.slice(-15).reverse().forEach(entry => {
                const key = getEntryKey(entry.caseId, entry.timestamp);

                const excludeBtn = document.getElementById(`exclude-${entry.caseId}-${entry.timestamp}`);
                if (excludeBtn) {
                    excludeBtn.addEventListener('click', () => {
                        toggleEntryExclusion(entry.caseId, entry.timestamp);
                        renderLog();
                    });
                }

                const deleteBtn = document.getElementById(`delete-${entry.caseId}-${entry.timestamp}`);
                if (deleteBtn) {
                    deleteBtn.addEventListener('click', () => {
                        if (confirm(`Delete this entry? You have 30 seconds to undo.`)) {
                            const updatedLog = log.filter(e =>
                                !(e.caseId === entry.caseId && e.timestamp === entry.timestamp)
                            );
                            safeSetStorage(CONFIG.storage.log, JSON.stringify(updatedLog));
                            saveToUndoHistory(entry);
                            renderLog();
                        }
                    });
                }
            });
        }, 100);

        logPanel.innerHTML = `
            <div style="background:#16213e;border-radius:6px;padding:8px;margin-bottom:8px;font-size:11px;">
                <div style="color:#00d4ff;font-weight:bold;margin-bottom:4px;">📋 CASE LOG</div>
                <div style="color:#aaa;font-size:10px;">
                    <strong>Total:</strong> ${log.length} |
                    <strong style="color:#e74c3c;">Excluded:</strong> ${excluded.length}
                </div>
                ${stats ? `<div style="color:#aaa;margin-top:4px;"><strong>Weighted DAG: <span style="color:${parseFloat(stats.weightedDAG) >= 100 ? '#2ecc71' : '#f39c12'}">${stats.weightedDAG}%</span></strong></div>` : ''}
            </div>

            ${duplicateWarning}

            <div style="background:#0f0f1a;border-radius:6px;padding:8px;margin-bottom:8px;border-left:4px solid #f39c12;">
                <div style="font-size:10px;color:#f39c12;font-weight:bold;">✗ Exclude / ✓ Include</div>
                <div style="font-size:9px;color:#aaa;">Click button to exclude/include this specific entry (other instances of same case kept)</div>
            </div>

            <div style="color:#aaa;font-size:10px;margin-bottom:4px;">Last 15 cases (most recent first):</div>
            ${rows}
        `;
    }

