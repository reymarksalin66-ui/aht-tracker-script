    function updateGoalsUI() {
        const emailInput = document.getElementById('aht-goal-email-input');
        const nonEmailInput = document.getElementById('aht-goal-nonemail-input');
        const photonInput = document.getElementById('aht-goal-photon-input');

        if (emailInput) emailInput.value = (AHT_GOALS.email / 60).toFixed(2);
        if (nonEmailInput) nonEmailInput.value = (AHT_GOALS.nonemail / 60).toFixed(2);
        if (photonInput) photonInput.value = (AHT_GOALS.photon / 60).toFixed(2);
    }

    function saveGoalsFromInputs() {
        try {
            const emailVal = parseFloat(document.getElementById('aht-goal-email-input').value);
            const nonEmailVal = parseFloat(document.getElementById('aht-goal-nonemail-input').value);
            const photonVal = parseFloat(document.getElementById('aht-goal-photon-input').value);

            if (isNaN(emailVal) || emailVal <= 0 || emailVal > 60) {
                alert('⚠️ Email goal must be 0.1-60 minutes');
                return false;
            }
            if (isNaN(nonEmailVal) || nonEmailVal <= 0 || nonEmailVal > 60) {
                alert('⚠️ Non-Email goal must be 0.1-60 minutes');
                return false;
            }
            if (isNaN(photonVal) || photonVal <= 0 || photonVal > 60) {
                alert('⚠️ Photon goal must be 0.1-60 minutes');
                return false;
            }

            AHT_GOALS.email = emailVal * 60;
            AHT_GOALS.nonemail = nonEmailVal * 60;
            AHT_GOALS.photon = photonVal * 60;

            saveGoals();
            updateCaseTypeUI();
            updateStatusMsg('✅ Goals saved!', '#2ecc71');

            return true;
        } catch (e) {
            console.error('❌ Error saving goals:', e);
            return false;
        }
    }

