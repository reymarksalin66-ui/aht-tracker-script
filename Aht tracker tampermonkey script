    function loadMinimizedState() {
        const stored = safeGetStorage(CONFIG.storage.minimized, false);
        return stored === true || stored === 'true';
    }

    function saveMinimizedState(minimized) {
        safeSetStorage(CONFIG.storage.minimized, minimized ? 'true' : 'false');
        isMinimized = minimized;
    }

    function toggleMinimize() {
        const panel = document.getElementById('aht-tracker-panel');
        const header = document.getElementById('aht-panel-header');
        const contentArea = document.getElementById('aht-panel-content');
        const minimizeBtn = document.getElementById('aht-btn-minimize');
        const minimizedSection = document.getElementById('aht-minimized-section');

        if (!panel || !contentArea || !minimizeBtn || !header) return;

        isMinimized = !isMinimized;
        saveMinimizedState(isMinimized);

        if (isMinimized) {
            contentArea.style.display = 'none';
            if (minimizedSection) minimizedSection.style.display = 'flex';
            minimizeBtn.textContent = '📍 Expand';
            header.style.borderRadius = '12px 12px 12px 12px';

            panel.style.height = 'auto';
            panel.style.minHeight = 'auto';
        } else {
            contentArea.style.display = 'flex';
            if (minimizedSection) minimizedSection.style.display = 'none';
            minimizeBtn.textContent = '📌 Min';
            header.style.borderRadius = '12px 12px 0 0';

            panel.style.height = '';
            panel.style.minHeight = '320px';
        }
    }

