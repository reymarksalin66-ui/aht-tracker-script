    let goalsEditorOpen = false;
    let statsEditorOpen = false;
    let pageLoadInitialized = false;
    let manuallyStoppedOnCase = null;
    let stoppedAtZero = false;
    let shouldAutoStartOnLoad = true;
    let lastUrl = location.href;

    // ═════════════════════════════════════════════════════════════════════════
    // 📦 DOM ELEMENT CACHE
    // ═════════════════════════════════════════════════════════════════════════

    const DOM = {
        panel: null,
        display: null,
        bar: null,
        dag: null,
        statusMsg: null,
        caseLabel: null,
        queueLabel: null,
        badge: null,
